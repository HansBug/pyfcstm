{ {{ machine_macro_name(model) }}_ACTION_KIND_{{ "ABSTRACT" if resolved.item.is_abstract else "CONCRETE" }}, {{ action_method_name(state, method_kind, idx) if not resolved.item.is_abstract else "NULL" }}, {{ hook_enum(resolved.item) if resolved.item.is_abstract else "-1" }}, {{ cstr(resolved.item.func_name) }}, {{ cstr(resolved.item.stage) }}, {{ state_enum(resolved.item.parent) }} }
