/* Error helpers used by the public API wrappers. */
static void _{{ machine_class_name(model) }}_set_error({{ machine_class_name(model) }} *machine, const char *fmt, ...)
{
    va_list ap;
    if (machine == NULL) {
        return;
    }
    va_start(ap, fmt);
    PYFCSTM_GENERATED_VSNPRINTF(machine->last_error, sizeof(machine->last_error), fmt, ap);
    machine->last_error[sizeof(machine->last_error) - 1u] = '\0';
    va_end(ap);
}

static void _{{ machine_class_name(model) }}_clear_error({{ machine_class_name(model) }} *machine)
{
    if (machine != NULL) {
        machine->last_error[0] = '\0';
    }
}

static int _{{ machine_class_name(model) }}_event_checks_required(void)
{
{% if all_events.items %}
    return 1;
{% else %}
    return 0;
{% endif %}
}

static int _{{ machine_class_name(model) }}_validate_event_checks(
    {{ machine_class_name(model) }} *machine,
    const {{ machine_class_name(model) }}EventChecks *event_checks)
{
    if (!_{{ machine_class_name(model) }}_event_checks_required()) {
        return {{ machine_macro_name(model) }}_SUCCESS;
    }
    if (event_checks == NULL) {
        _{{ machine_class_name(model) }}_set_error(
            machine,
            "Event checks are required before cycle(). Call {{ machine_class_name(model) }}_set_event_checks(...) with a complete generated event-check table.");
        return {{ machine_macro_name(model) }}_FAILURE;
    }
{% for event_path in all_events.items %}
    if (event_checks->{{ event_check_field_name(event_path) }} == NULL) {
        _{{ machine_class_name(model) }}_set_error(
            machine,
            "Missing required event check function: {{ machine_class_name(model) }}EventChecks.{{ event_check_field_name(event_path) }}.");
        return {{ machine_macro_name(model) }}_FAILURE;
    }
{% endfor %}
    return {{ machine_macro_name(model) }}_SUCCESS;
}

static int _{{ machine_class_name(model) }}_require_event_checks_mounted({{ machine_class_name(model) }} *machine)
{
    if (!_{{ machine_class_name(model) }}_event_checks_required()) {
        return {{ machine_macro_name(model) }}_SUCCESS;
    }
    if (machine != NULL && machine->event_checks_mounted) {
        return {{ machine_macro_name(model) }}_SUCCESS;
    }
    _{{ machine_class_name(model) }}_set_error(
        machine,
        "Event checks are not mounted for this c_poll runtime. Call {{ machine_class_name(model) }}_set_event_checks(...) with all generated check_xxx fields populated before cycle().");
    return {{ machine_macro_name(model) }}_FAILURE;
}

/* Active-vars selection lets validation run on temporary runtime snapshots. */
static const {{ machine_class_name(model) }}Vars *_{{ machine_class_name(model) }}_active_vars_const(
    const {{ machine_class_name(model) }} *machine)
{
    if (machine == NULL) {
        return NULL;
    }
    return machine->_active_vars != NULL ? machine->_active_vars : &machine->vars;
}

/* Reset persistent variables to the DSL `def ... = ...;` defaults. */
static void _{{ machine_class_name(model) }}_reset_vars({{ machine_class_name(model) }}Vars *vars)
