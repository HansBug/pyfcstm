{
  "name": "fcstm-language-support",
  "displayName": "FCSTM Language Support",
  "description": "Syntax highlighting and language support for FCSTM (Finite State Machine) DSL - a domain-specific language for modeling hierarchical state machines",
  "version": "0.1.0",
  "publisher": "hansbug",
  "author": {
    "name": "HansBug",
    "email": "hansbug@buaa.edu.cn"
  },
  "license": "LGPL-3.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "fcstm",
    "state machine",
    "fsm",
    "dsl",
    "finite state machine",
    "statechart",
    "harel",
    "hierarchical state machine",
    "syntax highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HansBug/pyfcstm.git"
  },
  "bugs": {
    "url": "https://github.com/HansBug/pyfcstm/issues"
  },
  "homepage": "https://github.com/HansBug/pyfcstm#readme",
  "qna": "https://github.com/HansBug/pyfcstm/discussions",
  "badges": [
    {
      "url": "https://img.shields.io/github/stars/HansBug/pyfcstm?style=social",
      "href": "https://github.com/HansBug/pyfcstm",
      "description": "Star pyfcstm on GitHub"
    }
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:fcstm"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.config.js --production",
    "watch": "node esbuild.config.js --watch",
    "compile:tsc": "tsc -p ./",
    "pretest": "npm run compile:tsc",
    "lint": "eslint src --ext ts",
    "package": "vsce package --out build/"
  },
  "dependencies": {
    "antlr4": "4.9.3"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vscode/vsce": "^2.15.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.0.0",
    "typescript": "^4.5.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "fcstm",
        "aliases": [
          "FCSTM",
          "fcstm"
        ],
        "extensions": [
          ".fcstm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fcstm",
        "scopeName": "source.fcstm",
        "path": "./syntaxes/fcstm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "fcstm",
        "path": "./snippets/fcstm.code-snippets"
      }
    ]
  }
}
