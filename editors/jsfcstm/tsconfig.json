{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2015",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2015"],
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"]
}
