## 快速开始

```c
#include "machine.h"

static int event_check(
    {{ machine_class_name(model) }} *machine,
    const {{ machine_class_name(model) }}EventContext *ctx,
    void *user_data
)
{
    (void)machine;
    (void)ctx;
    (void)user_data;
    return 0;  /* 当前 cycle 事件成立/触发时返回 1 或任意非零值。 */
               /* 当前 cycle 事件不成立/未触发时返回 0。 */
}

int main(void)
{
    {{ machine_class_name(model) }} machine;
{% if event_ns.items %}
    {{ machine_class_name(model) }}EventChecks event_checks = {{ machine_class_name(model) | upper }}_EVENT_CHECKS_INIT;
{% endif %}

    if (!{{ machine_class_name(model) }}_init(&machine)) {
        return 1;
    }
{% if event_ns.items %}

{% for event_path in event_ns.items %}
    event_checks.{{ event_check_field_id_name(event_path) }} = event_check;
{% endfor %}
    {{ machine_class_name(model) }}_set_event_checks(&machine, &event_checks, NULL);
{% endif %}

    if (!{{ machine_class_name(model) }}_cycle(&machine)) {
        return 2;
    }
    return 0;
}
