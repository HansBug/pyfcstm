static void _{{ machine_class_name(model) }}_execute_actions(
    {{ machine_class_name(model) }} *machine,
    const _{{ machine_class_name(model) }}ActionInfo *actions,
    size_t action_count,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    int is_validation_mode
)
{
    size_t i;
    {{ machine_class_name(model) }}ExecutionContext ctx;
    {{ machine_class_name(model) }}Vars *saved_active_vars;

    if (actions == NULL) {
        return;
    }

    for (i = 0u; i < action_count; ++i) {
        if (actions[i].kind == {{ machine_macro_name(model) }}_ACTION_KIND_CONCRETE) {
            actions[i].action_fn(&context->vars);
        } else if (!is_validation_mode) {
            saved_active_vars = machine->_active_vars;
            machine->_active_vars = &context->vars;
            ctx.state_path = _{{ machine_class_name(model) }}_state_info[actions[i].owner_state_id].path;
            ctx.vars = &context->vars;
            ctx.action_name = actions[i].action_name;
            ctx.action_stage = actions[i].action_stage;
            _{{ machine_class_name(model) }}_execute_abstract_hook(machine, actions[i].hook_id, &ctx);
            machine->_active_vars = saved_active_vars;
        }
    }
}

static void _{{ machine_class_name(model) }}_run_leaf_during(
    {{ machine_class_name(model) }} *machine,
    int state_id,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    int is_validation_mode
)
{
    int path_ids[{{ machine_macro_name(model) }}_MAX_STACK_DEPTH];
    size_t path_count;
    size_t i;
    const _{{ machine_class_name(model) }}StateInfo *state_info;

    state_info = &_{{ machine_class_name(model) }}_state_info[state_id];
    path_count = 0u;
    {
        int current = state_id;
        while (current >= 0) {
            path_ids[path_count++] = current;
            current = _{{ machine_class_name(model) }}_state_info[current].parent_state_id;
        }
    }

    if (!state_info->is_pseudo) {
        for (i = path_count; i > 0u; --i) {
            const _{{ machine_class_name(model) }}StateInfo *item_info = &_{{ machine_class_name(model) }}_state_info[path_ids[i - 1u]];
            _{{ machine_class_name(model) }}_execute_actions(
                machine,
                item_info->aspect_before_actions,
                item_info->aspect_before_action_count,
                context,
                is_validation_mode
            );
        }
    }

    _{{ machine_class_name(model) }}_execute_actions(
        machine,
        state_info->during_actions,
        state_info->during_action_count,
        context,
        is_validation_mode
    );

    if (!state_info->is_pseudo) {
        for (i = 0u; i < path_count; ++i) {
            const _{{ machine_class_name(model) }}StateInfo *item_info = &_{{ machine_class_name(model) }}_state_info[path_ids[i]];
            _{{ machine_class_name(model) }}_execute_actions(
                machine,
                item_info->aspect_after_actions,
                item_info->aspect_after_action_count,
                context,
                is_validation_mode
            );
        }
    }
}

static int _{{ machine_class_name(model) }}_transition_is_enabled(
    const _{{ machine_class_name(model) }}TransitionInfo *transition,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    const {{ machine_class_name(model) }}Vars *vars
)
{
    int event_id;
    if (transition->event_path == NULL) {
        event_id = -1;
    } else {
        event_id = _{{ machine_class_name(model) }}_lookup_event_id(transition->event_path);
    }
    if (!_{{ machine_class_name(model) }}_event_set_has(event_set, event_id)) {
        return 0;
    }
    if (transition->guard_fn != NULL && !transition->guard_fn(vars)) {
        return 0;
    }
    return 1;
}

static void _{{ machine_class_name(model) }}_execute_transition_effect(
    const _{{ machine_class_name(model) }}TransitionInfo *transition,
    _{{ machine_class_name(model) }}RuntimeContext *context
)
{
    if (transition->effect_fn != NULL) {
        transition->effect_fn(&context->vars);
    }
}

static int _{{ machine_class_name(model) }}_is_stoppable_state(int state_id)
{
    const _{{ machine_class_name(model) }}StateInfo *state_info = &_{{ machine_class_name(model) }}_state_info[state_id];
    return state_info->is_leaf && !state_info->is_pseudo;
}

static int _{{ machine_class_name(model) }}_validate_transition(
    {{ machine_class_name(model) }} *machine,
    const _{{ machine_class_name(model) }}RuntimeContext *context,
    int transition_id,
    const _{{ machine_class_name(model) }}EventSet *event_set
);

static int _{{ machine_class_name(model) }}_select_transition(
    {{ machine_class_name(model) }} *machine,
    const _{{ machine_class_name(model) }}RuntimeContext *context,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    int validate_stoppable
)
{
    int state_id;
    const _{{ machine_class_name(model) }}StateInfo *state_info;
    size_t i;
    int transition_id;
    const _{{ machine_class_name(model) }}TransitionInfo *transition;

    if (context->stack_size == 0u) {
        return -1;
    }

    state_id = context->stack[context->stack_size - 1u].state_id;
    state_info = &_{{ machine_class_name(model) }}_state_info[state_id];

    for (i = 0u; i < state_info->transition_count; ++i) {
        transition_id = state_info->transition_ids[i];
        transition = &_{{ machine_class_name(model) }}_transitions[transition_id];
        if (!_{{ machine_class_name(model) }}_transition_is_enabled(transition, event_set, &context->vars)) {
            continue;
        }
        if (validate_stoppable && _{{ machine_class_name(model) }}_is_stoppable_state(state_id)) {
            if (!_{{ machine_class_name(model) }}_validate_transition(machine, context, transition_id, event_set)) {
                continue;
            }
        }
        return transition_id;
    }

    return -1;
}

static int _{{ machine_class_name(model) }}_attempt_init_transition(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    int is_validation_mode
);

static int _{{ machine_class_name(model) }}_enter_state(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    int state_id,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    int is_validation_mode
)
{
    const _{{ machine_class_name(model) }}StateInfo *state_info;
    int init_result;

    state_info = &_{{ machine_class_name(model) }}_state_info[state_id];
    if (_{{ machine_class_name(model) }}_push_frame(machine, context, state_id, {{ machine_macro_name(model) }}_FRAME_MODE_ACTIVE) != {{ machine_macro_name(model) }}_SUCCESS) {
        if (is_validation_mode) {
            _{{ machine_class_name(model) }}_set_error(
                machine,
                "Speculative DFS exceeded the structural stack-depth safety limit (%d) without reaching a stoppable state or pruning; the state machine likely contains an invalid unbounded nesting chain.",
                {{ machine_macro_name(model) }}_MAX_STACK_DEPTH
            );
        }
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    _{{ machine_class_name(model) }}_execute_actions(
        machine,
        state_info->enter_actions,
        state_info->enter_action_count,
        context,
        is_validation_mode
    );

    if (state_info->is_leaf) {
        _{{ machine_class_name(model) }}_run_leaf_during(machine, state_id, context, is_validation_mode);
        context->stack[context->stack_size - 1u].mode = {{ machine_macro_name(model) }}_FRAME_MODE_AFTER_ENTRY;
        return {{ machine_macro_name(model) }}_SUCCESS;
    }

    _{{ machine_class_name(model) }}_execute_actions(
        machine,
        state_info->during_before_actions,
        state_info->during_before_action_count,
        context,
        is_validation_mode
    );
    context->stack[context->stack_size - 1u].mode = {{ machine_macro_name(model) }}_FRAME_MODE_INIT_WAIT;
    init_result = _{{ machine_class_name(model) }}_attempt_init_transition(machine, context, event_set, is_validation_mode);
    if (init_result != {{ machine_macro_name(model) }}_SUCCESS && machine != NULL && machine->last_error[0] != '\0') {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    return {{ machine_macro_name(model) }}_SUCCESS;
}

static int _{{ machine_class_name(model) }}_attempt_init_transition(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    int is_validation_mode
)
{
    int current_state_id;
    const _{{ machine_class_name(model) }}StateInfo *state_info;
    size_t i;
    int transition_id;
    const _{{ machine_class_name(model) }}TransitionInfo *transition;

    if (context->stack_size == 0u) {
        return 0;
    }

    current_state_id = context->stack[context->stack_size - 1u].state_id;
    state_info = &_{{ machine_class_name(model) }}_state_info[current_state_id];

    for (i = 0u; i < state_info->initial_transition_count; ++i) {
        transition_id = state_info->initial_transition_ids[i];
        transition = &_{{ machine_class_name(model) }}_transitions[transition_id];
        if (!_{{ machine_class_name(model) }}_transition_is_enabled(transition, event_set, &context->vars)) {
            continue;
        }
        _{{ machine_class_name(model) }}_execute_transition_effect(transition, context);
        if (_{{ machine_class_name(model) }}_enter_state(
            machine,
            context,
            transition->target_state_id,
            event_set,
            is_validation_mode
        ) != {{ machine_macro_name(model) }}_SUCCESS) {
            return 0;
        }
        return 1;
    }

    return 0;
}

static int _{{ machine_class_name(model) }}_finalize_exit_to_parent(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    int is_validation_mode
)
{
    int parent_state_id;
    const _{{ machine_class_name(model) }}StateInfo *parent_info;

    if (context->stack_size == 0u) {
        return 1;
    }

    parent_state_id = context->stack[context->stack_size - 1u].state_id;
    if (parent_state_id == {{ state_enum(model.root_state) }}) {
        context->stack_size = 0u;
        return 1;
    }

    parent_info = &_{{ machine_class_name(model) }}_state_info[parent_state_id];
    _{{ machine_class_name(model) }}_execute_actions(
        machine,
        parent_info->during_after_actions,
        parent_info->during_after_action_count,
        context,
        is_validation_mode
    );
    context->stack[context->stack_size - 1u].mode = {{ machine_macro_name(model) }}_FRAME_MODE_POST_CHILD_EXIT;
    return 0;
}

static int _{{ machine_class_name(model) }}_execute_transition_on_context(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    int transition_id,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    int is_validation_mode
)
{
    int current_state_id;
    const _{{ machine_class_name(model) }}StateInfo *state_info;
    const _{{ machine_class_name(model) }}TransitionInfo *transition;

    transition = &_{{ machine_class_name(model) }}_transitions[transition_id];
    current_state_id = context->stack[context->stack_size - 1u].state_id;
    state_info = &_{{ machine_class_name(model) }}_state_info[current_state_id];

    _{{ machine_class_name(model) }}_execute_actions(
        machine,
        state_info->exit_actions,
        state_info->exit_action_count,
        context,
        is_validation_mode
    );
    _{{ machine_class_name(model) }}_execute_transition_effect(transition, context);
    --context->stack_size;

    if (transition->to_exit) {
        return _{{ machine_class_name(model) }}_finalize_exit_to_parent(machine, context, is_validation_mode);
    }

    if (_{{ machine_class_name(model) }}_enter_state(
        machine,
        context,
        transition->target_state_id,
        event_set,
        is_validation_mode
    ) != {{ machine_macro_name(model) }}_SUCCESS) {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    return 0;
}

static int _{{ machine_class_name(model) }}_run_cycle_on_context(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    const _{{ machine_class_name(model) }}EventSet *event_set,
    int *ended,
    int validate_post_child_exit,
    int is_validation_mode
)
{
    int steps_taken;
    int signatures_seen;
    size_t i;

    (void)signatures_seen;

    steps_taken = 0;
    while (!(*ended)) {
        {{ machine_class_name(model) }}Frame *frame;
        int state_id;
        const _{{ machine_class_name(model) }}StateInfo *state_info;
        int transition_id;
        int structural_depth;

        if (context->stack_size == 0u) {
            *ended = 1;
            break;
        }

        structural_depth = (int)context->stack_size;
        if (structural_depth > {{ machine_macro_name(model) }}_MAX_STACK_DEPTH) {
            _{{ machine_class_name(model) }}_set_error(
                machine,
                "Speculative DFS exceeded the structural stack-depth safety limit (%d).",
                {{ machine_macro_name(model) }}_MAX_STACK_DEPTH
            );
            return {{ machine_macro_name(model) }}_FAILURE;
        }
        if (steps_taken >= {{ machine_macro_name(model) }}_MAX_DFS_STEPS) {
            return 0;
        }

        frame = &context->stack[context->stack_size - 1u];
        state_id = frame->state_id;
        state_info = &_{{ machine_class_name(model) }}_state_info[state_id];

        if (state_info->is_leaf) {
            if (frame->mode == {{ machine_macro_name(model) }}_FRAME_MODE_AFTER_ENTRY) {
                frame->mode = {{ machine_macro_name(model) }}_FRAME_MODE_ACTIVE;
                if (_{{ machine_class_name(model) }}_is_stoppable_state(state_id)) {
                    return 1;
                }
                ++steps_taken;
                continue;
            }

            transition_id = _{{ machine_class_name(model) }}_select_transition(
                machine,
                context,
                event_set,
                1
            );
            if (transition_id < 0 && machine != NULL && machine->last_error[0] != '\0') {
                return {{ machine_macro_name(model) }}_FAILURE;
            }
            if (transition_id >= 0) {
                *ended = _{{ machine_class_name(model) }}_execute_transition_on_context(
                    machine,
                    context,
                    transition_id,
                    event_set,
                    is_validation_mode
                );
                ++steps_taken;
                if (*ended) {
                    return 1;
                }
                continue;
            }

            _{{ machine_class_name(model) }}_run_leaf_during(machine, state_id, context, is_validation_mode);
            frame->mode = {{ machine_macro_name(model) }}_FRAME_MODE_AFTER_ENTRY;
            ++steps_taken;
            continue;
        }

        if (frame->mode == {{ machine_macro_name(model) }}_FRAME_MODE_INIT_WAIT) {
            if (!_{{ machine_class_name(model) }}_attempt_init_transition(machine, context, event_set, is_validation_mode)) {
                if (machine != NULL && machine->last_error[0] != '\0') {
                    return {{ machine_macro_name(model) }}_FAILURE;
                }
                return 0;
            }
            ++steps_taken;
            continue;
        }

        if (frame->mode == {{ machine_macro_name(model) }}_FRAME_MODE_POST_CHILD_EXIT) {
            transition_id = _{{ machine_class_name(model) }}_select_transition(
                machine,
                context,
                event_set,
                validate_post_child_exit
            );
            if (transition_id < 0 && machine != NULL && machine->last_error[0] != '\0') {
                return {{ machine_macro_name(model) }}_FAILURE;
            }
            if (transition_id < 0) {
                return 0;
            }
            *ended = _{{ machine_class_name(model) }}_execute_transition_on_context(
                machine,
                context,
                transition_id,
                event_set,
                is_validation_mode
            );
            ++steps_taken;
            if (*ended) {
                return 1;
            }
            continue;
        }

        for (i = 0u; i < context->stack_size; ++i) {
            if (context->stack[i].mode == frame->mode && context->stack[i].state_id == frame->state_id) {
                break;
            }
        }
        return 0;
    }

    return 1;
}

static int _{{ machine_class_name(model) }}_validate_transition(
    {{ machine_class_name(model) }} *machine,
    const _{{ machine_class_name(model) }}RuntimeContext *context,
    int transition_id,
    const _{{ machine_class_name(model) }}EventSet *event_set
)
{
    _{{ machine_class_name(model) }}RuntimeContext sim_context;
    int ended;

    _{{ machine_class_name(model) }}_copy_context(&sim_context, context);
    ended = _{{ machine_class_name(model) }}_execute_transition_on_context(
        machine,
        &sim_context,
        transition_id,
        event_set,
        1
    );
    if (machine != NULL && machine->last_error[0] != '\0') {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    if (ended) {
        return 1;
    }
    return _{{ machine_class_name(model) }}_run_cycle_on_context(
        machine,
        &sim_context,
        event_set,
        &ended,
        0,
        1
    );
}

static int _{{ machine_class_name(model) }}_initialize_context(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}RuntimeContext *context,
    const _{{ machine_class_name(model) }}EventSet *event_set
)
{
    context->stack_size = 0u;
    _{{ machine_class_name(model) }}_enter_state(machine, context, {{ state_enum(model.root_state) }}, event_set, 0);
    return context->stack_size == 0u;
}

{{ machine_class_name(model) }} *{{ machine_class_name(model) }}_create(void)
{
    {{ machine_class_name(model) }} *machine = ({{ machine_class_name(model) }} *)calloc(1u, sizeof({{ machine_class_name(model) }}));
    if (machine == NULL) {
