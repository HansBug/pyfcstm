    def register_abstract_handler(self, action_path, handler):
        """
        Register a runtime handler for an abstract DSL action.

        This composition-based extension path can be used together with
        subclass overrides of the generated protected hook methods.

        :param action_path: Full abstract action path from the DSL.
        :type action_path: str
        :param handler: Callable receiving :class:`ReadOnlyExecutionContext`.
        :type handler: Callable
        :return: ``None``.
        :rtype: None
