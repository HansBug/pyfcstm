// Demo: E_DUPLICATE_VAR — top-level def re-declares an identifier.
// Expected diagnostics:
//   * E_DUPLICATE_VAR at line 11 — counter declared again
//   * E_DUPLICATE_VAR at line 12 — temp declared again

def int counter = 0;
def float temp = 25.0;
def int unrelated = 42;
def int counter = 1;
def float temp = 30.0;

state Root {
    state Idle;
    [*] -> Idle;
}
