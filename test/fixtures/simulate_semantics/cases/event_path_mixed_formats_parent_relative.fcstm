def int counter = 0;
state Root {
    event global_event;
    state System {
        event system_event;
        state A {
            event local_a;
            during {
                counter = counter + 1;
            }
        }
        state B {
            event local_b;
            during {
                counter = counter + 10;
            }
        }
        [*] -> A;
        A -> B :: local_a;
        A -> B : system_event;
        A -> B : /global_event;
    }
    [*] -> System;
}
