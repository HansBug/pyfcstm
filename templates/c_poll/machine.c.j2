static int _{{ machine_class_name(model) }}_state_id_is_valid(int state_id)
{
    return state_id >= 0 && state_id < {{ machine_macro_name(model) }}_STATE_COUNT;
}

static int _{{ machine_class_name(model) }}_event_id_is_valid(int event_id)
{
    return event_id >= 0 && event_id < {{ machine_macro_name(model) }}_EVENT_COUNT;
}

static void _{{ machine_class_name(model) }}_event_set_reset(
    _{{ machine_class_name(model) }}EventSet *event_set,
    size_t input_count)
{
    size_t i;

    event_set->count = 0u;
    event_set->use_bitset =
        {{ machine_macro_name(model) }}_EVENT_COUNT > 0 &&
        {{ machine_macro_name(model) }}_EVENT_COUNT <= {{ machine_macro_name(model) }}_EVENTSET_BITSET_LIMIT_INTERNAL &&
        input_count > {{ machine_macro_name(model) }}_EVENTSET_SMALL_ARRAY_THRESHOLD_INTERNAL;
    if (event_set->use_bitset) {
        for (i = 0u; i < sizeof(event_set->bitset) / sizeof(event_set->bitset[0]); ++i) {
            event_set->bitset[i] = 0ul;
        }
    }
}

static int _{{ machine_class_name(model) }}_event_set_add(
    {{ machine_class_name(model) }} *machine,
    _{{ machine_class_name(model) }}EventSet *event_set,
    int event_id)
{
    size_t i;

    if (!_{{ machine_class_name(model) }}_event_id_is_valid(event_id)) {
        _{{ machine_class_name(model) }}_set_error(machine, "Invalid event id: %d", event_id);
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    if (event_set->use_bitset) {
        size_t word_index = (size_t)event_id / {{ machine_macro_name(model) }}_EVENTSET_WORD_BITS_INTERNAL;
        unsigned long mask = 1ul << ((size_t)event_id % {{ machine_macro_name(model) }}_EVENTSET_WORD_BITS_INTERNAL);
        if ((event_set->bitset[word_index] & mask) == 0ul) {
            event_set->bitset[word_index] |= mask;
            ++event_set->count;
        }
        return {{ machine_macro_name(model) }}_SUCCESS;
    }

    for (i = 0u; i < event_set->count; ++i) {
        if (event_set->ids[i] == event_id) {
            return {{ machine_macro_name(model) }}_SUCCESS;
        }
    }
    if (event_set->count >= sizeof(event_set->ids) / sizeof(event_set->ids[0])) {
        _{{ machine_class_name(model) }}_set_error(machine, "Too many events in one cycle.");
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    event_set->ids[event_set->count++] = event_id;
    return {{ machine_macro_name(model) }}_SUCCESS;
}

