    def _parse_event(self, event):
        if hasattr(event, "path_name"):
            event = event.path_name
        elif not isinstance(event, str):
            event = str(event)

        if not event:
            raise ValueError("Event reference cannot be empty")

        if not self._stack:
            if event in self._EVENT_PATH_SET:
                return event
            raise LookupError("Cannot resolve event %r after runtime end." % (event,))

        current_path = self._stack[-1]["state"]
        current_items = list(self._STATE_INFO[current_path]["path"])

        if event.startswith("/"):
            relative_path = event[1:]
            if not relative_path:
                raise ValueError("Absolute event reference cannot be just '/'.")
            candidate = self._ROOT_STATE_PATH + "." + relative_path
            if candidate in self._EVENT_PATH_SET:
                return candidate
            raise LookupError("Cannot resolve absolute event path %r." % (event,))

        if event.startswith("."):
            dot_count = 0
            for char in event:
                if char == ".":
                    dot_count += 1
                else:
                    break
            remaining_path = event[dot_count:]
            if not remaining_path:
                raise ValueError(
                    "Parent-relative event reference cannot end with dots: %r"
                    % (event,)
                )
            if dot_count > len(current_items) - 1:
                raise ValueError(
                    "Parent-relative event reference %r goes beyond root state."
                    % (event,)
                )
            base_items = current_items[:-dot_count]
            candidate = ".".join(tuple(base_items + remaining_path.split(".")))
            if candidate in self._EVENT_PATH_SET:
                return candidate
            raise LookupError(
                "Cannot resolve parent-relative event path %r." % (event,)
            )

        if event in self._EVENT_PATH_SET:
            return event

        candidate = current_path + "." + event
        if candidate in self._EVENT_PATH_SET:
            return candidate

        raise LookupError("Cannot resolve event path %r." % (event,))

    def _normalize_events(self, events):
        if events is None:
            return set()
        if isinstance(events, str):
            events = [events]
        normalized = set()
        for item in events:
            normalized.add(self._parse_event(item))
        return normalized

    def _iter_path_to_state(self, state_path):
        result = []
        current_path = state_path
        while current_path is not None:
            result.insert(0, current_path)
            current_path = self._STATE_INFO[current_path]["parent"]
        return result

    def _execute_actions(self, actions, vars_, is_validation_mode=False):
        for action in actions:
            if action["kind"] == "concrete":
                getattr(self, action["method"])(vars_)
            else:
