// Demo: E_UNDEFINED_VAR with ``is_temporary: true`` — block-local temporary
// variable read before it is assigned.
// Expected:
//   * E_UNDEFINED_VAR on the ``compute_me`` read in the enter block
//     (data.is_temporary should be ``true``)

state Root {
    state Idle {
        enter {
            // compute_me is read here before any assignment within this block
            tracker = compute_me + 1;
            compute_me = tracker * 2;
        }
    }
    [*] -> Idle;
}
