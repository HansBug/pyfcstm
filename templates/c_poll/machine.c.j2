{% if model.defines.values() | list -%}
{% for def_item in model.defines.values() -%}
{{ '    ' }}vars->{{ def_item.name | to_c_identifier }} = {{ def_item.init.to_ast_node() | expr_render(style='c') }};
{% endfor -%}
{% else -%}
    vars->_unused_placeholder = 0;
{% endif -%}
}

