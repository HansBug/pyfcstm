    {
      "id": "suggested_action_adversarial",
      "path": "suggested_action_adversarial.fcstm",
      "category": "suggested action 可能误导的对抗样例",
      "smoke": false,
      "enable_verify": true,
      "requires_max_tier": "smt_linear",
      "expected_codes": ["W_DEAD_GUARD"],
      "bad_repair_flags": ["guard-to-true", "delete-state", "delete-transition"],
