        for action in actions:
            if action['kind'] == 'concrete':
                getattr(self, action['method'])()
            else:
                self._execute_abstract_action(action)

    def _execute_abstract_action(self, action):
        ctx = ReadOnlyExecutionContext(
            state_path=action['owner_state_path'],
            vars=dict(self._vars),
            action_name=action['action_name'],
            action_stage=action['action_stage'],
        )
        hook_name = action.get('hook_method')
        if hook_name:
            getattr(self, hook_name)(ctx)
        handlers = self._abstract_handlers.get(action['action_name'], [])
        for handler in handlers:
            handler(ctx)

    def _run_leaf_during(self, state_path):
        state_info = self._STATE_INFO[state_path]
        if not state_info['is_pseudo']:
            for item_path in self._iter_path_to_state(state_path):
                self._execute_actions(self._STATE_INFO[item_path]['aspect_before_actions'])
        self._execute_actions(state_info['during_actions'])
        if not state_info['is_pseudo']:
            for item_path in reversed(self._iter_path_to_state(state_path)):
                self._execute_actions(self._STATE_INFO[item_path]['aspect_after_actions'])

    def _transition_matches_event(self, transition, event_names):
        if transition['event_path'] is None:
            return True
        return (
            transition['event_path'] in event_names or
            transition['event_name'] in event_names
        )

    def _transition_matches_guard(self, transition):
        if transition['guard'] is None:
            return True
        return bool(getattr(self, transition['guard'])())

    def _transition_is_enabled(self, transition, event_names):
        return self._transition_matches_event(transition, event_names) and self._transition_matches_guard(transition)

    def _select_transition(self, state_path, event_names):
        for transition_id in self._STATE_INFO[state_path]['transition_ids']:
            transition = self._TRANSITIONS[transition_id]
            if self._transition_is_enabled(transition, event_names):
                return transition_id
        return None

    def _enter_state(self, state_path, event_names):
        state_info = self._STATE_INFO[state_path]
        self._stack.append({'state': state_path, 'mode': 'active'})
        self._execute_actions(state_info['enter_actions'])

        if state_info['is_leaf']:
            self._run_leaf_during(state_path)
            self._stack[-1]['mode'] = 'after_entry'
        else:
            self._execute_actions(state_info['during_before_actions'])
            self._stack[-1]['mode'] = 'init_wait'
            self._attempt_init_transition(event_names)

    def _attempt_init_transition(self, event_names):
        if not self._stack:
            return False
        current_path = self._stack[-1]['state']
        for transition_id in self._STATE_INFO[current_path]['initial_transition_ids']:
            transition = self._TRANSITIONS[transition_id]
            if self._transition_is_enabled(transition, event_names):
                if transition['effect'] is not None:
                    getattr(self, transition['effect'])()
                self._enter_state(transition['target'], event_names)
                return True
        return False

    def _finalize_exit_to_parent(self):
        if not self._stack:
            self._ended = True
            return True

        parent_path = self._stack[-1]['state']
        if parent_path == self._ROOT_STATE_PATH:
            self._stack = []
            self._ended = True
            return True

        self._execute_actions(self._STATE_INFO[parent_path]['during_after_actions'])
        self._stack[-1]['mode'] = 'post_child_exit'
        return False

    def _execute_transition(self, transition_id, event_names):
        transition = self._TRANSITIONS[transition_id]
        current_path = self._stack[-1]['state']
        self._execute_actions(self._STATE_INFO[current_path]['exit_actions'])
        if transition['effect'] is not None:
            getattr(self, transition['effect'])()
        self._stack.pop()

        if transition['to_exit']:
            return self._finalize_exit_to_parent()

        self._enter_state(transition['target'], event_names)
        return False

    def cycle(self, events=None):
        """
        Advance the state machine by one cycle.

        :param events: Optional event name or event collection for this cycle.
        :type events: Optional[Union[str, List[str], Tuple[str, ...], set]]
        :return: Current leaf state path after the cycle, or ``None`` if ended.
        :rtype: Optional[Tuple[str, ...]]
        """
        event_names = self._normalize_events(events)
        if self._ended:
            return None

        if not self._entered_root:
            root_info = self._STATE_INFO[self._ROOT_STATE_PATH]
            self._execute_actions(root_info['enter_actions'])
            if root_info['is_leaf']:
                self._run_leaf_during(self._ROOT_STATE_PATH)
                self._stack[-1]['mode'] = 'after_entry'
            self._entered_root = True

        while not self._ended:
            if not self._stack:
                self._ended = True
                return None

            frame = self._stack[-1]
            state_path = frame['state']
            state_info = self._STATE_INFO[state_path]

            if state_info['is_leaf']:
                if frame['mode'] == 'after_entry':
                    frame['mode'] = 'active'
                    if not state_info['is_pseudo']:
                        return self.current_state_path
                    continue

                transition_id = self._select_transition(state_path, event_names)
                if transition_id is not None:
                    if self._execute_transition(transition_id, event_names):
                        return None
                    continue

                self._run_leaf_during(state_path)
                frame['mode'] = 'after_entry'
                continue

            if frame['mode'] == 'init_wait':
                if not self._attempt_init_transition(event_names):
                    raise RuntimeError(
                        'Composite state %r has no enabled initial transition.' % state_path
                    )
                continue

            if frame['mode'] == 'post_child_exit':
                transition_id = self._select_transition(state_path, event_names)
                if transition_id is None:
                    raise RuntimeError(
                        'No enabled transition available after child exit at %r.' % state_path
                    )
                if self._execute_transition(transition_id, event_names):
                    return None
                continue

            raise RuntimeError('Unknown frame mode %r for state %r.' % (frame['mode'], state_path))

        return None

