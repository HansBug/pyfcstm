static int _{{ machine_class_name(model) }}_parse_event(
    {{ machine_class_name(model) }} *machine,
    const _{{ machine_class_name(model) }}RuntimeContext *context,
    const char *event_ref,
    int *out_event_id
)
{
    char buffer[1024];
    const char *current_path;
    const char *root_path;
    const char *remaining;
    size_t dot_count;
    size_t current_len;
    size_t keep_len;
    int event_id;
    int current_state_id;

    if (event_ref == NULL || event_ref[0] == '\0') {
        _{{ machine_class_name(model) }}_set_error(machine, "Event reference cannot be empty");
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    root_path = _{{ machine_class_name(model) }}_state_info[{{ state_enum(model.root_state) }}].path;
    current_state_id = _{{ machine_class_name(model) }}_current_state_id_from_context(context);

    if (current_state_id < 0) {
        event_id = _{{ machine_class_name(model) }}_lookup_event_id(event_ref);
        if (event_id >= 0) {
            *out_event_id = event_id;
            return {{ machine_macro_name(model) }}_SUCCESS;
        }
        _{{ machine_class_name(model) }}_set_error(machine, "Cannot resolve event '%s' after runtime end.", event_ref);
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    current_path = _{{ machine_class_name(model) }}_state_info[current_state_id].path;

    if (event_ref[0] == '/') {
        remaining = event_ref + 1;
        if (remaining[0] == '\0') {
            _{{ machine_class_name(model) }}_set_error(machine, "Absolute event reference cannot be just '/'.");
            return {{ machine_macro_name(model) }}_FAILURE;
        }
        snprintf(buffer, sizeof(buffer), "%s.%s", root_path, remaining);
        event_id = _{{ machine_class_name(model) }}_lookup_event_id(buffer);
        if (event_id >= 0) {
            *out_event_id = event_id;
            return {{ machine_macro_name(model) }}_SUCCESS;
        }
        _{{ machine_class_name(model) }}_set_error(machine, "Cannot resolve absolute event path '%s'.", event_ref);
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    if (event_ref[0] == '.') {
        dot_count = 0u;
        while (event_ref[dot_count] == '.') {
            ++dot_count;
        }
        remaining = event_ref + dot_count;
        if (remaining[0] == '\0') {
            _{{ machine_class_name(model) }}_set_error(
                machine,
                "Parent-relative event reference cannot end with dots: '%s'",
                event_ref
            );
            return {{ machine_macro_name(model) }}_FAILURE;
        }
        current_len = strlen(current_path);
        keep_len = current_len;
        while (dot_count > 0u) {
            if (keep_len == 0u) {
                _{{ machine_class_name(model) }}_set_error(
                    machine,
                    "Parent-relative event reference '%s' goes beyond root state.",
                    event_ref
                );
                return {{ machine_macro_name(model) }}_FAILURE;
            }
            while (keep_len > 0u && current_path[keep_len - 1u] != '.') {
                --keep_len;
            }
            if (keep_len == 0u) {
                _{{ machine_class_name(model) }}_set_error(
                    machine,
                    "Parent-relative event reference '%s' goes beyond root state.",
                    event_ref
                );
                return {{ machine_macro_name(model) }}_FAILURE;
            }
            --keep_len;
            --dot_count;
        }
        if (keep_len >= sizeof(buffer) - 1u) {
            _{{ machine_class_name(model) }}_set_error(machine, "Resolved event path is too long.");
            return {{ machine_macro_name(model) }}_FAILURE;
        }
        memcpy(buffer, current_path, keep_len);
        buffer[keep_len] = '\0';
        snprintf(buffer + keep_len, sizeof(buffer) - keep_len, ".%s", remaining);
        event_id = _{{ machine_class_name(model) }}_lookup_event_id(buffer);
        if (event_id >= 0) {
            *out_event_id = event_id;
            return {{ machine_macro_name(model) }}_SUCCESS;
        }
        _{{ machine_class_name(model) }}_set_error(
            machine,
            "Cannot resolve parent-relative event path '%s'.",
            event_ref
        );
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    event_id = _{{ machine_class_name(model) }}_lookup_event_id(event_ref);
    if (event_id >= 0) {
        *out_event_id = event_id;
        return {{ machine_macro_name(model) }}_SUCCESS;
    }

    snprintf(buffer, sizeof(buffer), "%s.%s", current_path, event_ref);
    event_id = _{{ machine_class_name(model) }}_lookup_event_id(buffer);
    if (event_id >= 0) {
        *out_event_id = event_id;
        return {{ machine_macro_name(model) }}_SUCCESS;
    }

    _{{ machine_class_name(model) }}_set_error(machine, "Cannot resolve event path '%s'.", event_ref);
    return {{ machine_macro_name(model) }}_FAILURE;
}

static int _{{ machine_class_name(model) }}_normalize_events(
    {{ machine_class_name(model) }} *machine,
    const _{{ machine_class_name(model) }}RuntimeContext *context,
    const char *const *events,
    size_t event_count,
    _{{ machine_class_name(model) }}EventSet *out_event_set
)
{
    size_t i;
    int event_id;

    out_event_set->count = 0u;
    if (events == NULL) {
        return {{ machine_macro_name(model) }}_SUCCESS;
    }

    for (i = 0u; i < event_count; ++i) {
        if (_{{ machine_class_name(model) }}_parse_event(machine, context, events[i], &event_id) != {{ machine_macro_name(model) }}_SUCCESS) {
            return {{ machine_macro_name(model) }}_FAILURE;
        }
        if (_{{ machine_class_name(model) }}_event_set_add(out_event_set, event_id) != {{ machine_macro_name(model) }}_SUCCESS) {
            _{{ machine_class_name(model) }}_set_error(machine, "Too many events in one cycle.");
            return {{ machine_macro_name(model) }}_FAILURE;
        }
    }
    return {{ machine_macro_name(model) }}_SUCCESS;
}

