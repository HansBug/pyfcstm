{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2015",
    "outDir": "out",
    "lib": ["ES2015"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vscode"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out", "parser"]
}
