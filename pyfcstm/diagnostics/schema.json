{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/HansBug/pyfcstm/blob/main/pyfcstm/diagnostics/schema.json",
  "title": "ModelInspect",
  "description": "Shared contract between pyfcstm and jsfcstm for inspect_model() output, including structural data, derived graphs, and diagnostics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "root_state_path",
    "states",
    "transitions",
    "variables",
    "events",
    "actions",
    "forced_transitions",
    "metrics",
    "reachability_graph",
    "event_emission_map",
    "var_dataflow",
    "aspect_impact_map",
    "action_ref_graph",
    "diagnostics"
  ],
  "properties": {
    "root_state_path": {
      "type": "string",
      "description": "Dotted path of the model's root state."
    },
    "states": {
      "type": "array",
      "items": { "$ref": "#/definitions/StateInfo" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/definitions/TransitionInfo" }
    },
    "variables": {
      "type": "array",
      "items": { "$ref": "#/definitions/VariableInfo" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/definitions/EventInfo" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/definitions/ActionInfo" }
    },
    "forced_transitions": {
      "type": "array",
      "items": { "$ref": "#/definitions/ForcedTransitionInfo" }
    },
    "metrics": { "$ref": "#/definitions/ModelMetrics" },
    "reachability_graph": {
      "type": "object",
      "description": "Mapping state path -> reachable leaf state paths in the guard-agnostic topology projection. Keys include every state path; values are leaf-only paths and do not expose the synthetic root-exit sink.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "event_emission_map": {
      "type": "object",
      "description": "Mapping qualified event name -> source state paths that can emit it.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "var_dataflow": {
      "type": "object",
      "description": "Mapping variable name -> {reads: [...], writes: [...]} of state paths.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reads", "writes"],
        "properties": {
          "reads": {
            "type": "array",
            "items": { "type": "string" }
          },
          "writes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "aspect_impact_map": {
      "type": "object",
      "description": "Mapping composite path -> descendant leaf paths actually reached by aspect actions.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "action_ref_graph": {
      "type": "object",
      "description": "Mapping named-action function signature -> outgoing ref edge function signatures.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/definitions/ModelDiagnostic" }
    }
  },
  "definitions": {
    "StateInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path", "name", "parent_path", "is_leaf", "is_pseudo", "is_composite",
        "substates", "initial_targets", "entry_actions", "during_actions",
        "exit_actions", "aspect_before", "aspect_after", "has_abstract_action"
      ],
      "properties": {
        "path": { "type": "string" },
        "name": { "type": "string" },
        "parent_path": { "type": ["string", "null"] },
        "is_leaf": { "type": "boolean" },
        "is_pseudo": { "type": "boolean" },
        "is_composite": { "type": "boolean" },
        "substates": { "type": "array", "items": { "type": "string" } },
        "initial_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "guard", "event", "is_unconditional"],
            "properties": {
              "target": { "type": "string" },
              "guard": {
                "type": ["string", "null"],
                "description": "Normalized inspect expression text shared by pyfcstm and jsfcstm."
              },
              "event": { "type": ["string", "null"] },
              "is_unconditional": { "type": "boolean" }
            }
          }
        },
        "entry_actions": { "type": "array", "items": { "type": "string" } },
        "during_actions": { "type": "array", "items": { "type": "string" } },
        "exit_actions": { "type": "array", "items": { "type": "string" } },
        "aspect_before": { "type": "array", "items": { "type": "string" } },
        "aspect_after": { "type": "array", "items": { "type": "string" } },
        "has_abstract_action": { "type": "boolean" }
      }
    },
    "TransitionInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_path", "to_path", "event", "event_scope",
        "guard", "effect", "effect_self_assigns", "is_forced",
        "forced_origin", "transition_index"
      ],
      "properties": {
        "from_path": { "type": "string" },
        "to_path": { "type": "string" },
        "event": { "type": ["string", "null"] },
        "event_scope": {
          "type": ["string", "null"],
          "enum": ["local", "chain", "absolute", null]
        },
        "guard": {
          "type": ["string", "null"],
          "description": "Normalized inspect expression text shared by pyfcstm and jsfcstm."
        },
        "effect": { "type": ["string", "null"] },
        "effect_self_assigns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "is_forced": { "type": "boolean" },
        "forced_origin": { "type": ["string", "null"] },
        "transition_index": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Zero-based parent-first model transition order, including forced expansions at their declaring state."
        }
      }
    },
    "VariableInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", "type", "init_value",
        "read_in_states", "written_in_states",
        "read_in_guards", "written_in_effects",
        "affects_guard_directly", "affects_guard_indirectly",
        "abstract_actions_in_scope", "float_literal_assignments"
      ],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "init_value": { "type": "string" },
        "read_in_states": { "type": "array", "items": { "type": "string" } },
        "written_in_states": { "type": "array", "items": { "type": "string" } },
        "read_in_guards": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "written_in_effects": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "affects_guard_directly": { "type": "boolean" },
        "affects_guard_indirectly": { "type": "boolean" },
        "abstract_actions_in_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "float_literal_assignments": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "EventInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified_name", "scope", "used_by", "is_declared", "is_used"],
      "properties": {
        "qualified_name": { "type": "string" },
        "scope": { "type": "string", "enum": ["local", "chain", "absolute"] },
        "used_by": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "is_declared": { "type": "boolean" },
        "is_used": { "type": "boolean" }
      }
    },
    "ActionInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature", "state_path", "name", "stage", "aspect",
        "is_ref", "ref_target", "is_attached"
      ],
      "properties": {
        "signature": { "type": "string" },
        "state_path": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "stage": { "type": "string" },
        "aspect": { "type": ["string", "null"] },
        "is_ref": { "type": "boolean" },
        "ref_target": { "type": ["string", "null"] },
        "is_attached": { "type": "boolean" }
      }
    },
    "ForcedTransitionInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_path", "from_path", "to_path", "event", "event_scope",
        "guard", "original_raw", "expansion_count"
      ],
      "properties": {
        "state_path": { "type": "string" },
        "from_path": { "type": "string" },
        "to_path": { "type": "string" },
        "event": { "type": ["string", "null"] },
        "event_scope": {
          "type": ["string", "null"],
          "enum": ["local", "chain", "absolute", null]
        },
        "guard": {
          "type": ["string", "null"],
          "description": "Normalized inspect expression text shared by pyfcstm and jsfcstm."
        },
        "original_raw": { "type": "string" },
        "expansion_count": { "type": "integer", "minimum": 0 }
      }
    },
    "ModelMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "n_states_leaf", "n_states_composite", "n_states_pseudo",
        "max_hierarchy_depth", "n_transitions_normal", "n_transitions_forced",
        "n_events", "n_variables", "var_to_leaf_ratio",
        "aspect_coverage", "abstract_action_inventory"
      ],
      "properties": {
        "n_states_leaf": { "type": "integer", "minimum": 0 },
        "n_states_composite": { "type": "integer", "minimum": 0 },
        "n_states_pseudo": { "type": "integer", "minimum": 0 },
        "max_hierarchy_depth": { "type": "integer", "minimum": 0 },
        "n_transitions_normal": { "type": "integer", "minimum": 0 },
        "n_transitions_forced": { "type": "integer", "minimum": 0 },
        "n_events": { "type": "integer", "minimum": 0 },
        "n_variables": { "type": "integer", "minimum": 0 },
        "var_to_leaf_ratio": { "type": "number", "minimum": 0 },
        "aspect_coverage": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "abstract_action_inventory": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "SuggestedFixPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "anchor", "text", "rationale"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["insert", "delete", "replace"]
        },
        "target": { "type": "string", "minLength": 1 },
        "anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "ref"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ref"]
            },
            "ref": {
              "type": "string",
              "pattern": "^refs\\.[A-Za-z_][A-Za-z0-9_]*$"
            }
          }
        },
        "text": { "type": "string" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "ModelDiagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "span", "refs"],
      "properties": {
        "code": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        },
        "message": { "type": "string" },
        "span": {
          "description": "Primary problem range for the diagnostic. When non-null this is a pyfcstm Span using 1-based, end-exclusive coordinates and should point at the object described by the diagnostic message and code span_object.",
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/Span" }
          ]
        },
        "refs": {
          "type": "object",
          "description": "Structured payload declared in codes.yaml. Any refs key named <object>_span carries a Span for an auxiliary source object; keys ending in _spans carry list[Span]. These related ranges use the same 1-based, end-exclusive Span coordinates as ModelDiagnostic.span.",
          "properties": {
            "suggested_fix": { "$ref": "#/definitions/SuggestedFixPayload" },
            "transition_span": {
              "description": "Span for the transition related to the diagnostic.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/definitions/Span" }
              ]
            },
            "guard_span": {
              "description": "Span for the guard expression related to the diagnostic.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/definitions/Span" }
              ]
            },
            "forced_declaration_span": {
              "description": "Span for the forced-transition declaration related to the diagnostic.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/definitions/Span" }
              ]
            },
            "normal_transition_span": {
              "description": "Span for the normal transition related to a forced/normal pair diagnostic.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/definitions/Span" }
              ]
            },
            "previous_span": {
              "description": "Span for a previous declaration related to a duplicate diagnostic.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/definitions/Span" }
              ]
            },
            "duplicate_spans": {
              "description": "list[Span] for duplicate transitions related to a redundancy diagnostic.",
              "type": "array",
              "items": {
                "oneOf": [
                  { "type": "null" },
                  { "$ref": "#/definitions/Span" }
                ]
              }
            }
          },
          "additionalProperties": true
        }
      }
    },
    "Span": {
      "type": "object",
      "description": "Source span emitted by pyfcstm diagnostics and refs.<object>_span fields. Coordinates are 1-based and end-exclusive: line/column identify the first covered source position, and end_line/end_column identify the first source position after the covered text. jsfcstm consumers convert this to an LSP Range, which is 0-based and end-exclusive.",
      "additionalProperties": false,
      "required": ["line", "column", "end_line", "end_column"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based start line of the source span."
        },
        "column": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based start column of the source span."
        },
        "end_line": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }],
          "description": "1-based end line of the source span; null means the start line."
        },
        "end_column": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }],
          "description": "1-based end-exclusive column; null means a point-style span at column."
        }
      }
    }
  }
}
