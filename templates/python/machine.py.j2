    def _normalize_state_path(self, state_ref):
        if isinstance(state_ref, str):
            if not state_ref:
                raise ValueError("State path cannot be empty")
            path = tuple(state_ref.split("."))
        elif isinstance(state_ref, (tuple, list)):
            path = tuple(state_ref)
        else:
            raise TypeError("state_ref must be str, tuple, or list")

        if not path:
            raise ValueError("State path cannot be empty")
        if path[0] != self._ROOT_STATE_PATH:
            raise ValueError(
                "State path root %r does not match state machine root %r"
                % (path[0], self._ROOT_STATE_PATH)
            )

        current_path = self._ROOT_STATE_PATH
        for name in path[1:]:
            next_path = current_path + "." + name
            if next_path not in self._STATE_INFO:
                raise ValueError("State %r not found under %r" % (name, current_path))
            if self._STATE_INFO[next_path]["parent"] != current_path:
                raise ValueError(
                    "State %r is not a direct child of %r" % (name, current_path)
                )
            current_path = next_path

        return ".".join(path)

