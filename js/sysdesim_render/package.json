{
  "name": "@pyfcstm/sysdesim-render",
  "version": "0.1.0",
  "private": true,
  "description": "Self-rendering sequence-diagram SVG generator for SysDeSim timelines, bundled into the pyfcstm Python package and executed via mini-racer.",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=iife --target=es2015 --global-name=PyfcstmSysdesim --minify --legal-comments=none --outfile=dist/pyfcstm-sysdesim-render.js",
    "build:debug": "esbuild src/index.js --bundle --format=iife --target=es2015 --global-name=PyfcstmSysdesim --legal-comments=none --outfile=dist/pyfcstm-sysdesim-render.dev.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
