    machine->hooks = hooks;
    machine->hook_user_data = user_data;
}

int {{ machine_class_name(model) }}_cycle(
    {{ machine_class_name(model) }} *machine,
    const char *const *events,
    size_t event_count
)
{
    _{{ machine_class_name(model) }}RuntimeContext snapshot_context;
    _{{ machine_class_name(model) }}RuntimeContext sim_context;
    _{{ machine_class_name(model) }}EventSet event_set;
    int snapshot_entered_root;
    int snapshot_ended;
    int sim_entered_root;
    int sim_ended;
    int success;

    if (machine == NULL) {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    if (machine->ended) {
        return {{ machine_macro_name(model) }}_SUCCESS;
    }

    _{{ machine_class_name(model) }}_copy_from_machine(&snapshot_context, machine);
    _{{ machine_class_name(model) }}_copy_context(&sim_context, &snapshot_context);
    snapshot_entered_root = machine->entered_root;
    snapshot_ended = machine->ended;
    sim_entered_root = machine->entered_root;
    sim_ended = machine->ended;

    if (_{{ machine_class_name(model) }}_normalize_events(machine, &sim_context, events, event_count, &event_set) != {{ machine_macro_name(model) }}_SUCCESS) {
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    if (!sim_entered_root) {
        sim_ended = _{{ machine_class_name(model) }}_initialize_context(machine, &sim_context, &event_set);
        sim_entered_root = 1;
    }

    success = _{{ machine_class_name(model) }}_run_cycle_on_context(
        machine,
        &sim_context,
        &event_set,
        &sim_ended,
        1,
        0
    );

    if (success) {
        _{{ machine_class_name(model) }}_copy_to_machine(machine, &sim_context);
        machine->entered_root = sim_entered_root;
        machine->ended = sim_ended;
        _{{ machine_class_name(model) }}_clear_error(machine);
    } else {
        int has_error;

        has_error = machine->last_error[0] != '\0';
        _{{ machine_class_name(model) }}_copy_to_machine(machine, &snapshot_context);
        machine->ended = snapshot_ended;
        if (!snapshot_entered_root && !snapshot_ended) {
            machine->stack_size = 1u;
            machine->stack[0].state_id = {{ state_enum(model.root_state) }};
            machine->stack[0].mode = {{ machine_macro_name(model) }}_FRAME_MODE_INIT_WAIT;
            machine->entered_root = 1;
        } else {
            machine->entered_root = snapshot_entered_root;
        }
        if (!has_error) {
            _{{ machine_class_name(model) }}_clear_error(machine);
        }
    }

    if (machine->ended || machine->stack_size == 0u) {
        machine->ended = 1;
        machine->stack_size = 0u;
    }

    if (machine->last_error[0] != '\0') {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    return {{ machine_macro_name(model) }}_SUCCESS;
}

