    def _execute_abstract_action(self, action, vars_, is_validation_mode=False):
        if is_validation_mode:
            return
        ctx = ReadOnlyExecutionContext(
            state_path=action["owner_state_path"],
            vars=dict(vars_),
            action_name=action["action_name"],
            action_stage=action["action_stage"],
        )
        old_vars = self._vars
        old_variables = self.variables
        self._vars = vars_
        self.variables = self._vars
        try:
            hook_name = action.get("hook_method")
            if hook_name:
                getattr(self, hook_name)(ctx)
        finally:
            self._vars = old_vars
            self.variables = old_variables

    def _run_leaf_during(self, state_path, vars_, is_validation_mode=False):
