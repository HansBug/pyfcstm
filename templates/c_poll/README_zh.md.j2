### 函数使用说明

- `{{ machine_class_name(model) }}_create()` /
  `{{ machine_class_name(model) }}_destroy()`：
  适用于希望由生成运行时管理堆分配生命周期的场景。
- `{{ machine_class_name(model) }}_init()`：
  适用于栈上对象，或者对已有 machine 做重置。重置后应按需重新安装 hook 和 event-check 表。
- `{{ machine_class_name(model) }}_hot_start()`：
  `initial_vars` 必须是一个与 `initial_state_id` 兼容的完整持久变量快照。hot start 会保留已安装的 hook 表和 event-check 表。
- `{{ machine_class_name(model) }}_set_event_checks()`：
  对声明了事件的状态机，必须提供完整生成表。部分填充的表会被拒绝，并让 machine 继续处于不可运行状态。
- `{{ machine_class_name(model) }}_cycle()`：
  会使用当前已安装 event-check 表执行一个 cycle。如果表缺失或不完整，调用会返回
  `{{ machine_macro_name(model) }}_FAILURE`，并通过 `last_error` 解释原因。
- `{{ machine_class_name(model) }}_vars()`：
  返回的是只读指针；如果你需要一份可改的外部快照，请先把整个结构体拷贝出来。
- `{{ machine_class_name(model) }}_last_error()`：
  在任意 API 返回 `{{ machine_macro_name(model) }}_FAILURE` 后，应优先查看它。
- `{{ machine_class_name(model) }}_dsl_source()`：
  可用于诊断、追踪或把 canonical / normalized model export 暴露给上层工具。

## Minimal Complete Flow

```c
#include "machine.h"
#include <stdio.h>

{% if abstract_ns.rows -%}
static void generated_hook(
    {{ machine_class_name(model) }} *machine,
    const {{ machine_class_name(model) }}ExecutionContext *ctx,
    void *user_data
)
{
    (void)machine;
    (void)user_data;
    printf("hook: action=%d state=%d stage=%d\n", (int)ctx->action_id, (int)ctx->state_id, (int)ctx->action_stage_id);
}

{% endif -%}
{% if event_ns.items -%}
typedef struct DriverState {
    int trigger_selected_event;
} DriverState;

static int selected_event_check(
    {{ machine_class_name(model) }} *machine,
    const {{ machine_class_name(model) }}EventContext *ctx,
    void *user_data
)
{
    DriverState *driver = (DriverState *)user_data;
    (void)machine;
    (void)ctx;
    return driver->trigger_selected_event;
}

static int inactive_event_check(
    {{ machine_class_name(model) }} *machine,
    const {{ machine_class_name(model) }}EventContext *ctx,
    void *user_data
)
{
    (void)machine;
    (void)ctx;
    (void)user_data;
    return 0;
}

{% endif -%}
int main(void)
{
    {{ machine_class_name(model) }} machine;
{% if abstract_ns.rows %}
    {{ machine_class_name(model) }}Hooks hooks = {{ machine_class_name(model) | upper }}_HOOKS_INIT;
{% endif -%}
{% if event_ns.items %}
    {{ machine_class_name(model) }}EventChecks event_checks = {{ machine_class_name(model) | upper }}_EVENT_CHECKS_INIT;
    DriverState driver = {0};
{% endif %}

    if (!{{ machine_class_name(model) }}_init(&machine)) {
        return 1;
    }
{% if abstract_ns.rows %}
    hooks.{{ abstract_ns.rows[0]['hook_name'] }} = generated_hook;
    {{ machine_class_name(model) }}_set_hooks(&machine, &hooks, NULL);
{% endif %}
{% if event_ns.items %}
    /* Fill every generated event-check field before cycle(). */
{% for event_path in event_ns.items %}
    event_checks.{{ event_check_field_id_name(event_path) }} = {% if loop.first %}selected_event_check{% else %}inactive_event_check{% endif %};
{% endfor %}
    {{ machine_class_name(model) }}_set_event_checks(&machine, &event_checks, &driver);
{% endif %}
    if (!{{ machine_class_name(model) }}_cycle(&machine)) {
        return 2;
    }
{% if event_ns.items %}
    driver.trigger_selected_event = 1;
    if (!{{ machine_class_name(model) }}_cycle(&machine)) {
        return 3;
    }
{% endif %}
    printf("state id: %d\n", (int){{ machine_class_name(model) }}_current_state_id(&machine));
    return 0;
}
```

