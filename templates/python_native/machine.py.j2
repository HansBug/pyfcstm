def abstract_handler(action_path):
    """
    Mark a function or bound method as an abstract handler.

    :param action_path: Full action path.
    :type action_path: str
    :return: Decorator function.
    :rtype: Callable
    """
    if not action_path:
        raise ValueError('action_path cannot be empty')

    def decorator(func):
        setattr(func, _HANDLER_METADATA_ATTR, action_path)
        return func

    return decorator


def is_abstract_handler(func):
    """
    Check whether a function carries abstract-handler metadata.

    :param func: Callable to inspect.
    :type func: Callable
    :return: ``True`` if metadata exists.
    :rtype: bool
    """
    return hasattr(func, _HANDLER_METADATA_ATTR)


