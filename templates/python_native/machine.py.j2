        Methods decorated with :func:`abstract_handler` are discovered and
        registered automatically.

        :param obj: Object containing decorated bound methods.
        :type obj: object
        :return: Number of handlers registered.
        :rtype: int
        """
        count = 0
        for attr_name in dir(obj):
            attr = getattr(obj, attr_name)
            action_path = getattr(attr, _HANDLER_METADATA_ATTR, None)
            if action_path:
                self.register_abstract_handler(action_path, attr)
                count += 1
        return count

    def _normalize_state_path(self, state_ref):
        if isinstance(state_ref, str):
            if not state_ref:
                raise ValueError('State path cannot be empty')
            path = tuple(state_ref.split('.'))
        elif isinstance(state_ref, (tuple, list)):
            path = tuple(state_ref)
        else:
            raise TypeError('state_ref must be str, tuple, or list')

        if not path:
            raise ValueError('State path cannot be empty')
        if path[0] != self._ROOT_STATE_PATH:
            raise ValueError(
                "State path root %r does not match state machine root %r" % (path[0], self._ROOT_STATE_PATH)
            )

        current_path = self._ROOT_STATE_PATH
        for name in path[1:]:
            next_path = current_path + '.' + name
            if next_path not in self._STATE_INFO:
                raise ValueError("State %r not found under %r" % (name, current_path))
            if self._STATE_INFO[next_path]['parent'] != current_path:
                raise ValueError("State %r is not a direct child of %r" % (name, current_path))
            current_path = next_path

        return '.'.join(path)

    def _build_hot_start_stack(self, target_path):
        path_items = []
        current_path = target_path
        while current_path is not None:
            path_items.insert(0, current_path)
            current_path = self._STATE_INFO[current_path]['parent']

        stack = []
        for index, state_path in enumerate(path_items):
            state_info = self._STATE_INFO[state_path]
            is_target = index == len(path_items) - 1
            if state_info['is_leaf']:
                stack.append({'state': state_path, 'mode': 'active'})
            elif is_target:
                stack.append({'state': state_path, 'mode': 'init_wait'})
            else:
                stack.append({'state': state_path, 'mode': 'active'})
        return stack

    def _normalize_events(self, events):
        if events is None:
            return set()
        if isinstance(events, str):
            events = [events]
        normalized = set()
        for item in events:
            if isinstance(item, str):
                normalized.add(item)
            elif hasattr(item, 'path_name'):
                normalized.add(item.path_name)
            else:
                normalized.add(str(item))
        return normalized

    def _iter_path_to_state(self, state_path):
        result = []
        current_path = state_path
        while current_path is not None:
            result.insert(0, current_path)
            current_path = self._STATE_INFO[current_path]['parent']
        return result

