static void _{{ machine_class_name(model) }}_set_error({{ machine_class_name(model) }} *machine, const char *fmt, ...)
{
    va_list ap;
    if (machine == NULL) {
        return;
    }
    va_start(ap, fmt);
    vsnprintf(machine->last_error, sizeof(machine->last_error), fmt, ap);
    machine->last_error[sizeof(machine->last_error) - 1u] = '\0';
    va_end(ap);
}

static void _{{ machine_class_name(model) }}_clear_error({{ machine_class_name(model) }} *machine)
{
    if (machine != NULL) {
        machine->last_error[0] = '\0';
    }
}

static const char *_{{ machine_class_name(model) }}_frame_mode_name(int mode)
{
    switch (mode) {
        case {{ machine_macro_name(model) }}_FRAME_MODE_INIT_WAIT:
            return "init_wait";
        case {{ machine_macro_name(model) }}_FRAME_MODE_ACTIVE:
            return "active";
        case {{ machine_macro_name(model) }}_FRAME_MODE_AFTER_ENTRY:
            return "after_entry";
        case {{ machine_macro_name(model) }}_FRAME_MODE_POST_CHILD_EXIT:
            return "post_child_exit";
        default:
            return "unknown";
    }
}

static const {{ machine_class_name(model) }}Vars *_{{ machine_class_name(model) }}_active_vars_const(
    const {{ machine_class_name(model) }} *machine
)
{
    if (machine == NULL) {
        return NULL;
    }
    return machine->_active_vars != NULL ? machine->_active_vars : &machine->vars;
}

static {{ machine_class_name(model) }}Vars *_{{ machine_class_name(model) }}_active_vars(
    {{ machine_class_name(model) }} *machine
)
{
    if (machine == NULL) {
        return NULL;
    }
    return machine->_active_vars != NULL ? machine->_active_vars : &machine->vars;
}

