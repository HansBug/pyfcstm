def int x = 0;
state Root {
    state A;

    state Bad {
        enter abstract /* anonymous action */;

        state Done;

        [*] -> Done : if [x < 0];
    }

    state Good {
        during {
            x = -1;
        }
    }

    [*] -> A;
    A -> Bad :: Go;
    A -> Good :: Go;
    Good -> Bad :: TryBad;
}
