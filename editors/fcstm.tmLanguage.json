{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FCSTM",
  "scopeName": "source.fcstm",
  "fileTypes": ["fcstm"],
  "patterns": [
    {"include": "#comments"},
    {"include": "#declarations"},
    {"include": "#keywords"},
    {"include": "#operators"},
    {"include": "#constants"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#identifiers"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.fcstm",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.fcstm",
              "match": "."
            }
          ]
        },
        {
          "name": "comment.line.double-slash.fcstm",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.fcstm",
          "match": "#.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.definition.variable.fcstm",
          "match": "\\b(def)\\s+(int|float)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.fcstm"
            },
            "2": {
              "name": "storage.type.fcstm"
            },
            "3": {
              "name": "variable.other.definition.fcstm"
            }
          }
        },
        {
          "name": "meta.definition.pseudo-state.fcstm",
          "match": "\\b(pseudo)\\s+(state)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.fcstm"
            },
            "2": {
              "name": "keyword.control.fcstm"
            },
            "3": {
              "name": "entity.name.type.state.fcstm"
            }
          }
        },
        {
          "name": "meta.definition.state.fcstm",
          "match": "\\b(state)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.fcstm"
            },
            "2": {
              "name": "entity.name.type.state.fcstm"
            }
          }
        },
        {
          "name": "meta.definition.event.fcstm",
          "match": "\\b(event)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.fcstm"
            },
            "2": {
              "name": "entity.name.event.fcstm"
            }
          }
        },
        {
          "name": "meta.definition.import.block.fcstm",
          "begin": "\\b(import)\\s+((?:\"[^\"]*\"|'[^']*'))\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s+(named)\\s+((?:\"[^\"]*\"|'[^']*')))?\\s*(\\{)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.fcstm"
            },
            "2": {
              "name": "string.quoted.double.fcstm"
            },
            "3": {
              "name": "keyword.control.fcstm"
            },
            "4": {
              "name": "entity.name.type.state.fcstm"
            },
            "5": {
              "name": "keyword.control.fcstm"
            },
            "6": {
              "name": "string.quoted.double.fcstm"
            },
            "7": {
              "name": "punctuation.section.mapping.fcstm"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.mapping.fcstm"
            }
          },
          "patterns": [
            {
              "include": "#import-body"
            }
          ]
        },
        {
          "name": "meta.definition.import.fcstm",
          "match": "\\b(import)\\s+((?:\"[^\"]*\"|'[^']*'))\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b(?:\\s+(named)\\s+((?:\"[^\"]*\"|'[^']*')))?",
          "captures": {
            "1": {
              "name": "keyword.control.fcstm"
            },
            "2": {
              "name": "string.quoted.double.fcstm"
            },
            "3": {
              "name": "keyword.control.fcstm"
            },
            "4": {
              "name": "entity.name.type.state.fcstm"
            },
            "5": {
              "name": "keyword.control.fcstm"
            },
            "6": {
              "name": "string.quoted.double.fcstm"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fcstm",
          "match": "\\b(state|pseudo|named|def|event|import|as|if|else)\\b"
        },
        {
          "name": "keyword.other.lifecycle.fcstm",
          "match": "\\b(enter|during|exit|before|after)\\b"
        },
        {
          "name": "keyword.other.modifier.fcstm",
          "match": "\\b(abstract|ref|effect)\\b"
        },
        {
          "name": "storage.type.fcstm",
          "match": "\\b(int|float)\\b"
        },
        {
          "name": "keyword.operator.word.fcstm",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.aspect.fcstm",
          "match": ">>"
        },
        {
          "name": "keyword.operator.transition.fcstm",
          "match": "->"
        },
        {
          "name": "punctuation.separator.mapping.fcstm",
          "match": ","
        },
        {
          "name": "punctuation.section.mapping.fcstm",
          "match": "\\{|\\}"
        },
        {
          "name": "constant.language.pseudo-state.fcstm",
          "match": "\\[\\*\\]"
        },
        {
          "name": "keyword.operator.scope.fcstm",
          "match": "::"
        },
        {
          "name": "punctuation.separator.transition.fcstm",
          "match": ":"
        },
        {
          "name": "keyword.operator.path.fcstm",
          "match": "/"
        },
        {
          "name": "keyword.operator.arithmetic.fcstm",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.bitshift.fcstm",
          "match": "<<"
        },
        {
          "name": "keyword.operator.comparison.fcstm",
          "match": "<=|>=|==|!="
        },
        {
          "name": "keyword.operator.logical.fcstm",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.forced.fcstm",
          "match": "!"
        },
        {
          "name": "keyword.operator.arithmetic.fcstm",
          "match": "[+\\-*%&|^~<>]"
        },
        {
          "name": "keyword.operator.assignment.fcstm",
          "match": "=|\\?"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.fcstm",
          "match": "\\b(True|true|TRUE|False|false|FALSE)\\b"
        },
        {
          "name": "constant.language.math.fcstm",
          "match": "\\b(pi|E|tau)\\b"
        },
        {
          "name": "support.function.builtin.fcstm",
          "match": "\\b(sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|asinh|acosh|atanh|sqrt|cbrt|exp|log|log10|log2|log1p|abs|ceil|floor|round|trunc|sign)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fcstm",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fcstm",
              "match": "\\\\([btnfr\"'\\\\]|[0-7]{1,3}|u[0-9a-fA-F]{4}|x[0-9a-fA-F]{2})"
            }
          ]
        },
        {
          "name": "string.quoted.single.fcstm",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.fcstm",
              "match": "\\\\([btnfr\"'\\\\]|[0-7]{1,3}|u[0-9a-fA-F]{4}|x[0-9a-fA-F]{2})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.fcstm",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.fcstm",
          "match": "\\b([0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?|\\.[0-9]+([eE][+-]?[0-9]+)?|[0-9]+[eE][+-]?[0-9]+)\\b"
        },
        {
          "name": "constant.numeric.integer.fcstm",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.fcstm",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "import-body": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#strings"
        },
        {
          "name": "keyword.control.fcstm",
          "match": "\\b(def|event|named)\\b"
        },
        {
          "name": "keyword.operator.transition.fcstm",
          "match": "->"
        },
        {
          "name": "variable.parameter.fcstm",
          "match": "\\$\\{[0-9]+\\}|\\$[0-9]+"
        },
        {
          "name": "variable.parameter.fcstm",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\$\\{[0-9]+\\}|\\$[0-9]+|\\*)[A-Za-z0-9_*${}]*"
        },
        {
          "name": "variable.parameter.fcstm",
          "match": "\\*[A-Za-z0-9_${}][A-Za-z0-9_*${}]*"
        },
        {
          "name": "keyword.operator.wildcard.fcstm",
          "match": "\\*"
        },
        {
          "name": "keyword.operator.path.fcstm",
          "match": "/"
        },
        {
          "name": "punctuation.separator.mapping.fcstm",
          "match": ","
        },
        {
          "include": "#import-selector-set"
        },
        {
          "name": "variable.other.fcstm",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "import-selector-set": {
      "patterns": [
        {
          "name": "meta.import.selector-set.fcstm",
          "begin": "\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.mapping.fcstm"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.mapping.fcstm"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "punctuation.separator.mapping.fcstm",
              "match": ","
            },
            {
              "name": "variable.other.fcstm",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            }
          ]
        }
      ]
    }
  }
}
