    def _normalize_state_path(self, state_ref):
        if isinstance(state_ref, str):
            if not state_ref:
                raise ValueError("State path cannot be empty")
            path = tuple(state_ref.split("."))
        elif isinstance(state_ref, (tuple, list)):
            path = tuple(state_ref)
        else:
            raise TypeError("state_ref must be str, tuple, or list")

        if not path:
            raise ValueError("State path cannot be empty")
        if path[0] != self._ROOT_STATE_PATH:
            raise ValueError(
                "State path root %r does not match state machine root %r"
                % (path[0], self._ROOT_STATE_PATH)
            )

        current_path = self._ROOT_STATE_PATH
        for name in path[1:]:
            next_path = current_path + "." + name
            if next_path not in self._STATE_INFO:
                raise ValueError("State %r not found under %r" % (name, current_path))
            if self._STATE_INFO[next_path]["parent"] != current_path:
                raise ValueError(
                    "State %r is not a direct child of %r" % (name, current_path)
                )
            current_path = next_path

        return ".".join(path)

    def _build_hot_start_stack(self, target_path):
        path_items = []
        current_path = target_path
        while current_path is not None:
            path_items.insert(0, current_path)
            current_path = self._STATE_INFO[current_path]["parent"]

        stack = []
        for index, state_path in enumerate(path_items):
            state_info = self._STATE_INFO[state_path]
            is_target = index == len(path_items) - 1
            if state_info["is_leaf"]:
                stack.append({"state": state_path, "mode": "active"})
            elif is_target:
                stack.append({"state": state_path, "mode": "init_wait"})
            else:
                stack.append({"state": state_path, "mode": "active"})
        return stack

    def _validate_hot_start_stack(self, target_path):
        max_structural_depth = 64
        if len(self._stack) > max_structural_depth:
            raise SimulationRuntimeDfsError(
                "Hot start target exceeds the structural stack-depth safety limit "
                "(%s) before execution; choose a shallower target state or simplify "
                "the state hierarchy." % (max_structural_depth,)
            )

        if self._is_stoppable_state(target_path):
            return

        validation_stack = self._clone_stack(self._stack)
        validation_vars = dict(self._vars)
        dfs_error = None
        try:
            success, _ = self._run_cycle_on_context(
                validation_stack,
                validation_vars,
                set(),
                is_validation_mode=True,
            )
        except SimulationRuntimeDfsError as err:
            # _run_cycle_on_context can exceed DFS limits while proving that a
            # hot-start target has no empty-event stable path.
            dfs_error = err
            success = False
        if not success:
            if self._can_hot_start_wait_for_evented_initial(target_path):
                if dfs_error is not None:
                    raise dfs_error
                return
            target_display = ".".join(self._STATE_INFO[target_path]["path"])
            raise ValueError(
                "Hot start target %r cannot reach a stoppable state" % (target_display,)
            )

    def _can_hot_start_wait_for_evented_initial(self, target_path):
        if self._STATE_INFO[target_path]["is_leaf"]:
            return False

        worklist = [(self._clone_stack(self._stack), dict(self._vars))]
        seen_signatures = set()
        steps_taken = 0
        max_steps = 1000
        max_structural_depth = 64

        while worklist:
            current_stack, current_vars = worklist.pop()
            if not current_stack:
                continue

            structural_signature = self._create_structural_signature(current_stack)
            if len(structural_signature) > max_structural_depth:
                raise SimulationRuntimeDfsError(
                    "Hot start event-gated initial-chain search exceeded the "
                    "structural stack-depth safety limit "
                    "(%s); choose a shallower target state or simplify the state "
                    "hierarchy." % (max_structural_depth,)
                )

            signature = self._create_execution_signature(current_stack, current_vars)
            if signature in seen_signatures:
                continue
            seen_signatures.add(signature)

            if steps_taken >= max_steps:
                raise SimulationRuntimeDfsError(
                    "Hot start event-gated initial-chain search exceeded the "
                    "step safety limit (%s); the state machine likely contains "
                    "an invalid unbounded initial-transition chain." % (max_steps,)
                )
            steps_taken += 1

            frame = current_stack[-1]
            state_path = frame["state"]
            state_info = self._STATE_INFO[state_path]
            if state_info["is_leaf"] or frame["mode"] != "init_wait":
                continue

            for transition_id in state_info["initial_transition_ids"]:
                transition = self._TRANSITIONS[transition_id]
                if transition["event_path"] is None:
                    continue
                if self._transition_matches_guard(transition, current_vars):
                    return True

            for transition_id in reversed(state_info["initial_transition_ids"]):
                transition = self._TRANSITIONS[transition_id]
                if transition["event_path"] is not None:
                    continue
                if not self._transition_matches_guard(transition, current_vars):
                    continue

                next_stack = self._clone_stack(current_stack)
                next_vars = dict(current_vars)
                self._execute_initial_transition_on_context(
                    next_stack,
                    next_vars,
                    transition_id,
                    set(),
                    is_validation_mode=True,
                    attempt_initial_transition=False,
                )
                worklist.append((next_stack, next_vars))

        return False

    @staticmethod
    def _clone_stack(stack):
        return [dict(frame) for frame in stack]

    @staticmethod
    def _frame_plain_before_pending(frame):
        return bool(frame.get("plain_before_pending", False))

    @staticmethod
    def _create_execution_signature(stack, vars_):
        return (
            tuple(
                (
                    frame["state"],
                    frame["mode"],
                    {{ machine_class_name(model) }}._frame_plain_before_pending(frame),
                )
                for frame in stack
            ),
            tuple((key, vars_[key]) for key in sorted(vars_)),
        )

    @staticmethod
    def _create_structural_signature(stack):
        return tuple(
            (
                frame["state"],
                frame["mode"],
                {{ machine_class_name(model) }}._frame_plain_before_pending(frame),
            )
            for frame in stack
        )

    def _create_root_rollback_stack(self):
        return [
            {
                "state": self._ROOT_STATE_PATH,
                "mode": "init_wait",
                "plain_before_pending": False,
            }
        ]

    def _is_stoppable_state(self, state_path):
        state_info = self._STATE_INFO[state_path]
        return state_info["is_leaf"] and not state_info["is_pseudo"]

    def _parse_event(self, event):
        if hasattr(event, "path_name"):
            event = event.path_name
        elif not isinstance(event, str):
            event = str(event)

        if not event:
            raise ValueError("Event reference cannot be empty")

        if not self._stack:
            if event in self._EVENT_PATH_SET:
                return event
            raise LookupError("Cannot resolve event %r after runtime end." % (event,))

        current_path = self._stack[-1]["state"]
        current_items = list(self._STATE_INFO[current_path]["path"])

        if event.startswith("/"):
            relative_path = event[1:]
            if not relative_path:
                raise ValueError("Absolute event reference cannot be just '/'.")
            candidate = self._ROOT_STATE_PATH + "." + relative_path
            if candidate in self._EVENT_PATH_SET:
                return candidate
            raise LookupError("Cannot resolve absolute event path %r." % (event,))

        if event.startswith("."):
            dot_count = 0
            for char in event:
                if char == ".":
                    dot_count += 1
                else:
                    break
            remaining_path = event[dot_count:]
            if not remaining_path:
                raise ValueError(
                    "Parent-relative event reference cannot end with dots: %r"
                    % (event,)
                )
            if dot_count > len(current_items) - 1:
                raise ValueError(
                    "Parent-relative event reference %r goes beyond root state."
                    % (event,)
                )
            base_items = current_items[:-dot_count]
            candidate = ".".join(tuple(base_items + remaining_path.split(".")))
            if candidate in self._EVENT_PATH_SET:
                return candidate
            raise LookupError(
                "Cannot resolve parent-relative event path %r." % (event,)
            )

        if event in self._EVENT_PATH_SET:
            return event

        candidate = current_path + "." + event
        if candidate in self._EVENT_PATH_SET:
            return candidate

        raise LookupError("Cannot resolve event path %r." % (event,))

    def _normalize_events(self, events):
        if events is None:
            return set()
        if isinstance(events, str):
            events = [events]
        normalized = set()
        for item in events:
            normalized.add(self._parse_event(item))
        return normalized

    def _iter_path_to_state(self, state_path):
        result = []
        current_path = state_path
        while current_path is not None:
            result.insert(0, current_path)
            current_path = self._STATE_INFO[current_path]["parent"]
        return result

    def _execute_actions(
        self, actions, vars_, is_validation_mode=False, active_leaf_path=None
    ):
        for action in actions:
            if action["kind"] == "concrete":
                getattr(self, action["method"])(vars_)
            else:
                self._execute_abstract_action(
                    action,
                    vars_,
                    is_validation_mode=is_validation_mode,
                    active_leaf_path=active_leaf_path,
                )

    def _execute_abstract_action(
        self,
        action,
        vars_,
        is_validation_mode=False,
        active_leaf_path=None,
    ):
        if is_validation_mode:
            return
        if active_leaf_path is None:
            context_state_path = action["context_state_path"]
        else:
            # Aspect actions pass the active leaf path at runtime; the
            # action metadata path is only the owner-state fallback.
            context_state_path = active_leaf_path
        ctx = ReadOnlyExecutionContext(
            state_path=context_state_path,
            vars=dict(vars_),
            action_name=action["action_name"],
            action_stage=action["action_stage"],
            active_leaf=context_state_path,
            call_stage=action["call_stage"],
            abstract_target=action["abstract_target"],
            named_ref=action["named_ref"],
        )
        old_vars = self._vars
        old_variables = self.variables
        self._vars = vars_
        self.variables = self._vars
        try:
            hook_name = action.get("hook_method")
            if hook_name:
                getattr(self, hook_name)(ctx)
        finally:
            self._vars = old_vars
            self.variables = old_variables

    def _run_leaf_during(self, state_path, vars_, is_validation_mode=False):
        state_info = self._STATE_INFO[state_path]
        if not state_info["is_pseudo"]:
            for item_path in self._iter_path_to_state(state_path):
                self._execute_actions(
                    self._STATE_INFO[item_path]["aspect_before_actions"],
                    vars_,
                    is_validation_mode=is_validation_mode,
                    active_leaf_path=state_info["path"],
                )
        self._execute_actions(
            state_info["during_actions"],
            vars_,
            is_validation_mode=is_validation_mode,
        )
        if not state_info["is_pseudo"]:
            for item_path in reversed(self._iter_path_to_state(state_path)):
                self._execute_actions(
                    self._STATE_INFO[item_path]["aspect_after_actions"],
                    vars_,
                    is_validation_mode=is_validation_mode,
                    active_leaf_path=state_info["path"],
                )

    def _transition_matches_event(self, transition, event_names):
        if transition["event_path"] is None:
            return True
        return transition["event_path"] in event_names

    def _evaluate_runtime_expr(self, fn, usage):
        try:
            return fn()
        except (ValueError, ArithmeticError, TypeError) as err:
            # ValueError: math domain errors or invalid numeric operations
            # raised while evaluating a user's DSL expression.
            # ArithmeticError: division by zero, overflow, or other numeric
            # runtime failure while evaluating a user's DSL expression.
            # TypeError: Python numeric, bitwise, and shift operators reject
            # runtime operand combinations such as ``float << int``.
            raise SimulationRuntimeExpressionError(
                "%s evaluation failed: %s" % (usage, err)
            ) from err

    def _transition_matches_guard(self, transition, vars_):
        if transition["guard"] is None:
            return True
        return bool(getattr(self, transition["guard"])(vars_))

    def _transition_is_enabled(self, transition, event_names, vars_):
        return self._transition_matches_event(
            transition, event_names
        ) and self._transition_matches_guard(transition, vars_)

    def _execute_transition_effect(self, transition, vars_, is_validation_mode=False):
        if transition["effect"] is not None:
            getattr(self, transition["effect"])(vars_)

    def _select_transition(
        self,
        stack,
        vars_,
        event_names,
        validate_stoppable=True,
        force_validate=False,
    ):
        if not stack:
            return None
        state_path = stack[-1]["state"]
        state_info = self._STATE_INFO[state_path]
        for transition_id in state_info["transition_ids"]:
            transition = self._TRANSITIONS[transition_id]
            if not self._transition_is_enabled(transition, event_names, vars_):
                continue
            if validate_stoppable and (
                self._is_stoppable_state(state_path) or force_validate
            ):
                if not self._validate_transition(
                    stack, vars_, transition_id, event_names
                ):
                    continue
            return transition_id
        return None

    def _enter_state(
        self,
        stack,
        state_path,
        vars_,
        event_names,
        is_validation_mode=False,
        attempt_initial_transition=True,
    ):
        state_info = self._STATE_INFO[state_path]
        stack.append({"state": state_path, "mode": "active"})
        self._execute_actions(
            state_info["enter_actions"], vars_, is_validation_mode=is_validation_mode
        )

        if state_info["is_leaf"]:
            self._run_leaf_during(
                state_path, vars_, is_validation_mode=is_validation_mode
            )
            stack[-1]["mode"] = "after_entry"
        else:
            stack[-1]["mode"] = "init_wait"
            stack[-1]["plain_before_pending"] = True
            if attempt_initial_transition:
                self._attempt_init_transition(
                    stack, vars_, event_names, is_validation_mode=is_validation_mode
                )

    def _attempt_init_transition(
        self, stack, vars_, event_names, is_validation_mode=False
    ):
        if not stack:
            return False
        current_path = stack[-1]["state"]
        for transition_id in self._STATE_INFO[current_path]["initial_transition_ids"]:
            transition = self._TRANSITIONS[transition_id]
            if self._transition_is_enabled(transition, event_names, vars_):
                if not self._validate_initial_transition(
                    stack, vars_, transition_id, event_names
                ):
                    continue
                self._execute_initial_transition_on_context(
                    stack,
                    vars_,
                    transition_id,
                    event_names,
                    is_validation_mode=is_validation_mode,
                    attempt_initial_transition=not is_validation_mode,
                )
                return True
        return False

    def _execute_initial_transition_on_context(
        self,
        stack,
        vars_,
        transition_id,
        event_names,
        is_validation_mode=False,
        attempt_initial_transition=True,
    ):
        composite_frame = stack[-1]
        transition = self._TRANSITIONS[transition_id]
        self._execute_transition_effect(
            transition, vars_, is_validation_mode=is_validation_mode
        )
        if composite_frame.get("plain_before_pending", False):
            self._execute_actions(
                self._STATE_INFO[composite_frame["state"]]["during_before_actions"],
                vars_,
                is_validation_mode=is_validation_mode,
            )
            composite_frame["plain_before_pending"] = False
        self._enter_state(
            stack,
            transition["target"],
            vars_,
            event_names,
            is_validation_mode=is_validation_mode,
            attempt_initial_transition=attempt_initial_transition,
        )
        if any(frame is composite_frame for frame in stack):
            composite_frame["mode"] = "active"

    def _validate_initial_transition(self, stack, vars_, transition_id, event_names):
        sim_stack = self._clone_stack(stack)
        sim_vars = dict(vars_)
        self._execute_initial_transition_on_context(
            sim_stack,
            sim_vars,
            transition_id,
            event_names,
            is_validation_mode=True,
            attempt_initial_transition=False,
        )
        return self._validation_search_reaches_stable(sim_stack, sim_vars, event_names)

    def _finalize_exit_to_parent(self, stack, vars_, is_validation_mode=False):
        if not stack:
            return True

        parent_path = stack[-1]["state"]
        if parent_path == self._ROOT_STATE_PATH:
            self._execute_actions(
                self._STATE_INFO[parent_path]["during_after_actions"],
                vars_,
                is_validation_mode=is_validation_mode,
            )
            self._execute_actions(
                self._STATE_INFO[parent_path]["exit_actions"],
                vars_,
                is_validation_mode=is_validation_mode,
            )
            stack[:] = []
            return True

        self._execute_actions(
            self._STATE_INFO[parent_path]["during_after_actions"],
            vars_,
            is_validation_mode=is_validation_mode,
        )
        stack[-1]["mode"] = "post_child_exit"
        return False

    def _execute_transition_on_context(
        self, stack, vars_, transition_id, event_names, is_validation_mode=False
    ):
        transition = self._TRANSITIONS[transition_id]
        current_path = stack[-1]["state"]
        self._execute_actions(
            self._STATE_INFO[current_path]["exit_actions"],
            vars_,
            is_validation_mode=is_validation_mode,
        )
        self._execute_transition_effect(
            transition, vars_, is_validation_mode=is_validation_mode
        )
        stack.pop()

        if transition["to_exit"]:
            return self._finalize_exit_to_parent(
                stack, vars_, is_validation_mode=is_validation_mode
            )

        self._enter_state(
            stack,
            transition["target"],
            vars_,
            event_names,
            is_validation_mode=is_validation_mode,
        )
        return False

    def _validate_transition(self, stack, vars_, transition_id, event_names):
        sim_stack = self._clone_stack(stack)
        sim_vars = dict(vars_)
        ended = self._execute_transition_on_context(
            sim_stack,
            sim_vars,
            transition_id,
            event_names,
            is_validation_mode=True,
        )
        if ended:
            return True
        return self._validation_search_reaches_stable(
            sim_stack,
            sim_vars,
            event_names,
            ended=ended,
            validate_post_child_exit=True,
        )

    def _validation_search_reaches_stable(
        self,
        stack,
        vars_,
        event_names,
        ended=False,
        validate_post_child_exit=True,
    ):
        if ended:
            stack[:] = []
            vars_.clear()
            return True

        worklist = [(self._clone_stack(stack), dict(vars_), False)]
        seen_signatures = set()
        steps_taken = 0
        max_steps = 1000
        max_structural_depth = 64

        while worklist:
            current_stack, current_vars, current_ended = worklist.pop()
            if current_ended:
                stack[:] = []
                vars_.clear()
                vars_.update(current_vars)
                return True
            if not current_stack:
                stack[:] = []
                vars_.clear()
                vars_.update(current_vars)
                return True

            structural_signature = self._create_structural_signature(current_stack)
            if len(structural_signature) > max_structural_depth:
                raise SimulationRuntimeDfsError(
                    "Speculative DFS exceeded the structural stack-depth safety limit "
                    "(%s) without reaching a stoppable state or pruning; "
                    "the state machine likely contains an invalid unbounded nesting chain."
                    % (max_structural_depth,)
                )

            signature = self._create_execution_signature(current_stack, current_vars)
            if signature in seen_signatures:
                continue
            seen_signatures.add(signature)

            if steps_taken >= max_steps:
                raise SimulationRuntimeDfsError(
                    "Speculative DFS exceeded the step safety limit "
                    "(%s) without reaching a stoppable state or pruning; "
                    "the state machine likely contains an invalid unbounded pseudo-state "
                    "or transition chain." % (max_steps,)
                )
            steps_taken += 1

            frame = current_stack[-1]
            state_path = frame["state"]
            state_info = self._STATE_INFO[state_path]

            if state_info["is_leaf"] and frame["mode"] == "after_entry":
                next_stack = self._clone_stack(current_stack)
                next_vars = dict(current_vars)
                next_stack[-1]["mode"] = "active"
                if self._is_stoppable_state(state_path):
                    stack[:] = next_stack
                    vars_.clear()
                    vars_.update(next_vars)
                    return True
                worklist.append((next_stack, next_vars, False))
                continue

            if state_info["is_leaf"]:
                progressed = False
                for transition_id in reversed(state_info["transition_ids"]):
                    transition = self._TRANSITIONS[transition_id]
                    if not self._transition_is_enabled(
                        transition, event_names, current_vars
                    ):
                        continue
                    next_stack = self._clone_stack(current_stack)
                    next_vars = dict(current_vars)
                    next_ended = self._execute_transition_on_context(
                        next_stack,
                        next_vars,
                        transition_id,
                        event_names,
                        is_validation_mode=True,
                    )
                    worklist.append((next_stack, next_vars, next_ended))
                    progressed = True
                if progressed:
                    continue

                if not self._is_stoppable_state(state_path):
                    continue

                next_stack = self._clone_stack(current_stack)
                next_vars = dict(current_vars)
                self._run_leaf_during(state_path, next_vars, is_validation_mode=True)
                next_stack[-1]["mode"] = "after_entry"
                worklist.append((next_stack, next_vars, False))
                continue

            if frame["mode"] == "init_wait":
                progressed = False
                for transition_id in reversed(state_info["initial_transition_ids"]):
                    transition = self._TRANSITIONS[transition_id]
                    if not self._transition_is_enabled(
                        transition, event_names, current_vars
                    ):
                        continue
                    next_stack = self._clone_stack(current_stack)
                    next_vars = dict(current_vars)
                    self._execute_initial_transition_on_context(
                        next_stack,
                        next_vars,
                        transition_id,
                        event_names,
                        is_validation_mode=True,
                        attempt_initial_transition=False,
                    )
                    worklist.append((next_stack, next_vars, False))
                    progressed = True
                if not progressed:
                    continue
                continue

            if frame["mode"] == "post_child_exit":
                if not validate_post_child_exit:
                    continue
                for transition_id in reversed(state_info["transition_ids"]):
                    transition = self._TRANSITIONS[transition_id]
                    if not self._transition_is_enabled(
                        transition, event_names, current_vars
                    ):
                        continue
                    next_stack = self._clone_stack(current_stack)
                    next_vars = dict(current_vars)
                    next_ended = self._execute_transition_on_context(
                        next_stack,
                        next_vars,
                        transition_id,
                        event_names,
                        is_validation_mode=True,
                    )
                    worklist.append((next_stack, next_vars, next_ended))
                continue

        return False

    def _initialize_context(self, stack, vars_, event_names, is_validation_mode=False):
        stack[:] = []
        self._enter_state(
            stack,
            self._ROOT_STATE_PATH,
            vars_,
            event_names,
            is_validation_mode=is_validation_mode,
        )
        return len(stack) == 0

    def _run_cycle_on_context(
        self,
        stack,
        vars_,
        event_names,
        ended=False,
        validate_post_child_exit=True,
        is_validation_mode=False,
    ):
        if ended:
            return True, True

        steps_taken = 0
        max_steps = 1000
        seen_signatures = set()
        max_structural_depth = 64

        while not ended:
            if not stack:
                ended = True
                break

            signature = self._create_execution_signature(stack, vars_)
            if signature in seen_signatures:
                return False, False
            seen_signatures.add(signature)

            if len(self._create_structural_signature(stack)) > max_structural_depth:
                raise SimulationRuntimeDfsError(
                    "Speculative DFS exceeded the structural stack-depth safety limit "
                    "(%s) without reaching a stoppable state or pruning; "
                    "the state machine likely contains an invalid unbounded nesting chain."
                    % (max_structural_depth,)
                )

            if steps_taken >= max_steps:
                raise SimulationRuntimeDfsError(
                    "Speculative DFS exceeded the step safety limit "
                    "(%s) without reaching a stoppable state or pruning; "
                    "the state machine likely contains an invalid unbounded pseudo-state "
                    "or transition chain." % (max_steps,)
                )

            frame = stack[-1]
            state_path = frame["state"]
            state_info = self._STATE_INFO[state_path]

            if state_info["is_leaf"]:
                if frame["mode"] == "after_entry":
                    frame["mode"] = "active"
                    if self._is_stoppable_state(state_path):
                        return True, False
                    steps_taken += 1
                    continue

                transition_id = self._select_transition(
                    stack,
                    vars_,
                    event_names,
                    force_validate=state_info["is_pseudo"],
                )
                if transition_id is not None:
                    ended = self._execute_transition_on_context(
                        stack,
                        vars_,
                        transition_id,
                        event_names,
                        is_validation_mode=is_validation_mode,
                    )
                    steps_taken += 1
                    if ended:
                        return True, True
                    continue

                self._run_leaf_during(
                    state_path, vars_, is_validation_mode=is_validation_mode
                )
                frame["mode"] = "after_entry"
                steps_taken += 1
                continue

            if frame["mode"] == "init_wait":
                progressed = self._attempt_init_transition(
                    stack,
                    vars_,
                    event_names,
                    is_validation_mode=is_validation_mode,
                )
                steps_taken += 1
                if not progressed:
                    return False, False
                continue

            if frame["mode"] == "post_child_exit":
                transition_id = self._select_transition(
                    stack,
                    vars_,
                    event_names,
                    validate_stoppable=validate_post_child_exit,
                    force_validate=validate_post_child_exit,
                )
                if transition_id is None:
                    return False, False
                ended = self._execute_transition_on_context(
                    stack,
                    vars_,
                    transition_id,
                    event_names,
                    is_validation_mode=is_validation_mode,
                )
                steps_taken += 1
                if ended:
                    return True, True
                continue

            return False, False

        return True, True

    def cycle(self, events=None):
        """
        Advance the state machine by one cycle.

        :param events: Optional event name or event collection for this cycle.
        :type events: Optional[Union[str, List[str], Tuple[str, ...], set]]
        :return: Current leaf state path after the cycle, or ``None`` if ended.
        :rtype: Optional[Tuple[str, ...]]
        """
        if self._ended:
            return None
        event_names = self._normalize_events(events)

        snapshot_stack = self._clone_stack(self._stack)
        snapshot_vars = dict(self._vars)
        snapshot_entered_root = self._entered_root
        snapshot_ended = self._ended

        validation_stack = self._clone_stack(snapshot_stack)
        validation_vars = dict(snapshot_vars)
        validation_entered_root = snapshot_entered_root
        validation_ended = snapshot_ended

        if not validation_entered_root:
            validation_ended = self._initialize_context(
                validation_stack,
                validation_vars,
                event_names,
                is_validation_mode=True,
            )
            validation_entered_root = True

        success, validation_ended = self._run_cycle_on_context(
            validation_stack,
            validation_vars,
            event_names,
            ended=validation_ended,
            is_validation_mode=True,
        )

        if success:
            sim_stack = self._clone_stack(snapshot_stack)
            sim_vars = dict(snapshot_vars)
            sim_entered_root = snapshot_entered_root
            sim_ended = snapshot_ended

            if not sim_entered_root:
                sim_ended = self._initialize_context(sim_stack, sim_vars, event_names)
                sim_entered_root = True

            success, sim_ended = self._run_cycle_on_context(
                sim_stack,
                sim_vars,
                event_names,
                ended=sim_ended,
            )

        if success:
            self._stack = [] if sim_ended else sim_stack
            self._vars = sim_vars
            self.variables = self._vars
            self._entered_root = sim_entered_root
            self._ended = sim_ended
            self.cycle_count += 1
        else:
            self._vars = snapshot_vars
            self.variables = self._vars
            self._ended = snapshot_ended
            if not snapshot_entered_root and not snapshot_ended:
                self._stack = self._create_root_rollback_stack()
            else:
                self._stack = snapshot_stack
            self._entered_root = snapshot_entered_root

        if self._ended or not self._stack:
            self._ended = True
            self._stack = []

        return None

