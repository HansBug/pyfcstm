int {{ machine_class_name(model) }}_cycle(
    {{ machine_class_name(model) }} *machine)
{
    _{{ machine_class_name(model) }}RuntimeContext sim_context;
    _{{ machine_class_name(model) }}EventSet event_set;
    int sim_entered_root;
    int sim_ended;
    int success;

    if (machine == NULL) {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    if (machine->ended) {
        return {{ machine_macro_name(model) }}_SUCCESS;
    }
    if (_{{ machine_class_name(model) }}_require_event_checks_mounted(machine) != {{ machine_macro_name(model) }}_SUCCESS) {
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    _{{ machine_class_name(model) }}_copy_from_machine(&sim_context, machine);
    sim_entered_root = machine->entered_root;
    sim_ended = machine->ended;

    if (_{{ machine_class_name(model) }}_normalize_events(machine, NULL, 0u, &event_set) != {{ machine_macro_name(model) }}_SUCCESS) {
        return {{ machine_macro_name(model) }}_FAILURE;
    }

    if (!sim_entered_root) {
        sim_ended = _{{ machine_class_name(model) }}_initialize_context(machine, &sim_context, &event_set);
        sim_entered_root = 1;
    }

    success = _{{ machine_class_name(model) }}_run_cycle_on_context(
        machine,
        &sim_context,
        &event_set,
        &sim_ended,
        1,
        0);

    if (success) {
        _{{ machine_class_name(model) }}_copy_to_machine(machine, &sim_context);
        machine->entered_root = sim_entered_root;
        machine->ended = sim_ended;
        if (machine->ended || machine->stack_size == 0u) {
            machine->ended = 1;
            machine->stack_size = 0u;
        }
        _{{ machine_class_name(model) }}_clear_error(machine);
    }

    if (!success && machine->last_error[0] != '\0') {
        return {{ machine_macro_name(model) }}_FAILURE;
    }
    return {{ machine_macro_name(model) }}_SUCCESS;
}

