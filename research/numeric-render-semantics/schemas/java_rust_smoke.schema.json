{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HansBug/pyfcstm/research/numeric-render-semantics/schemas/java_rust_smoke.schema.json",
  "title": "Java and Rust numeric smoke summary",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "language",
    "source_mapping_sha256",
    "render_mapping_sha256",
    "summary_status",
    "generator",
    "repository",
    "toolchain",
    "official_source_notes",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "mode": {
      "enum": [
        "java-smoke",
        "rust-smoke",
        "java-rust-smoke"
      ]
    },
    "language": {
      "enum": [
        "java",
        "rust",
        "java-rust"
      ]
    },
    "source_mapping_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "render_mapping_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "summary_status": {
      "type": "string"
    },
    "generator": {
      "type": "object",
      "required": [
        "tool",
        "research_path",
        "source_commit",
        "source_commit_policy",
        "determinism"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "research_path": {
          "type": "string"
        },
        "source_commit": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{40}$"
        },
        "source_commit_policy": {
          "type": "string"
        },
        "determinism": {
          "type": "string"
        }
      }
    },
    "repository": {
      "type": "object",
      "required": [
        "root",
        "render_mapping_snapshot",
        "schema_path"
      ]
    },
    "toolchain": {
      "type": "object"
    },
    "render_paths": {
      "type": "array"
    },
    "official_source_notes": {
      "type": [
        "array",
        "object"
      ]
    },
    "languages": {
      "type": "object",
      "required": [
        "java",
        "rust"
      ]
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/native_case"
      }
    },
    "validation_errors": {
      "type": "array"
    }
  },
  "$defs": {
    "native_case": {
      "type": "object",
      "required": [
        "case_id",
        "semantic_case_id",
        "language",
        "profile",
        "operator",
        "fcstm_expression",
        "render_path",
        "render_expression",
        "native_api_family",
        "native_only",
        "native_only_reason",
        "inputs",
        "source_note_ids",
        "status",
        "outcome",
        "reason",
        "commands"
      ],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "semantic_case_id": {
          "type": "string"
        },
        "language": {
          "enum": [
            "java",
            "rust"
          ]
        },
        "profile": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "fcstm_expression": {
          "type": "string"
        },
        "render_path": {
          "type": "string"
        },
        "render_expression": {
          "type": "string"
        },
        "native_api_family": {
          "enum": [
            "plain-int32",
            "plain-i32",
            "checked-exact",
            "narrowing-cast",
            "cast",
            "math-floating",
            "renderer-fallback",
            "wrapping",
            "checked",
            "overflowing",
            "saturating"
          ]
        },
        "native_only": {
          "const": true
        },
        "native_only_reason": {
          "const": "no_java_or_rust_template_in_current_repository"
        },
        "inputs": {
          "type": "object",
          "required": [
            "A",
            "B"
          ]
        },
        "source_note_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "status": {
          "enum": [
            "passed",
            "compile_failed",
            "runtime_failed",
            "skipped",
            "unavailable",
            "unknown"
          ]
        },
        "outcome": {
          "enum": [
            "observed",
            "compile_failed",
            "runtime_trap",
            "unavailable",
            "unknown"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "commands": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  }
}
