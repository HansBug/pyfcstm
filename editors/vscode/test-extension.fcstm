def int counter = 0;
def float temperature = 25.5;

state System {
    event Start named "Start Event";
    event Stop;

    >> during before {
        counter = counter + 1;
    }

    state Idle {
        enter {
            counter = 0;
        }
    }

    state Running {
        during {
            temperature = temperature + 0.1;
        }

        state Active;
        state Paused;
    }

    [*] -> Idle;
    Idle -> Running :: Start;
    Running -> Idle : Stop;
}

// 故意写一些错误来测试诊断
state Error
