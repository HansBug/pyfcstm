{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HansBug/pyfcstm/research/numeric-render-semantics/schemas/java_rust_smoke.schema.json",
  "title": "Java and Rust numeric smoke summary",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "language",
    "source_mapping_sha256",
    "render_mapping_sha256",
    "summary_status",
    "generator",
    "repository",
    "toolchain",
    "official_source_notes",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "mode": {
      "enum": [
        "java-smoke",
        "rust-smoke",
        "java-rust-smoke"
      ]
    },
    "language": {
      "enum": [
        "java",
        "rust",
        "java-rust"
      ]
    },
    "source_mapping_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "render_mapping_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "summary_status": {
      "enum": [
        "passed",
        "unavailable",
        "completed_with_findings",
        "completed",
        "skipped",
        "invalid"
      ]
    },
    "generator": {
      "type": "object",
      "required": [
        "tool",
        "research_path",
        "source_commit",
        "source_commit_policy",
        "determinism"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "research_path": {
          "type": "string"
        },
        "source_commit": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{40}$"
        },
        "source_commit_policy": {
          "type": "string"
        },
        "determinism": {
          "type": "string"
        }
      }
    },
    "repository": {
      "type": "object",
      "required": [
        "root",
        "render_mapping_snapshot",
        "schema_path"
      ]
    },
    "toolchain": {
      "type": "object"
    },
    "render_paths": {
      "type": "array"
    },
    "official_source_notes": {
      "type": [
        "array",
        "object"
      ]
    },
    "languages": {
      "type": "object",
      "required": [
        "java",
        "rust"
      ],
      "properties": {
        "java": {
          "$ref": "#/$defs/java_payload"
        },
        "rust": {
          "$ref": "#/$defs/rust_payload"
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/native_case"
      }
    },
    "validation_errors": {
      "type": "array"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "const": "java-smoke"
          }
        }
      },
      "then": {
        "required": [
          "language"
        ],
        "properties": {
          "language": {
            "const": "java"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "const": "rust-smoke"
          }
        }
      },
      "then": {
        "required": [
          "language"
        ],
        "properties": {
          "language": {
            "const": "rust"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "const": "java-rust-smoke"
          }
        }
      },
      "then": {
        "required": [
          "language",
          "languages"
        ],
        "properties": {
          "language": {
            "const": "java-rust"
          },
          "languages": {
            "type": "object",
            "required": [
              "java",
              "rust"
            ]
          }
        }
      }
    },
    {
      "description": "Committed rust-unavailable snapshot shape",
      "if": {
        "required": [
          "toolchain"
        ],
        "properties": {
          "toolchain": {
            "type": "object",
            "required": [
              "rust"
            ],
            "properties": {
              "rust": {
                "type": "object",
                "required": [
                  "rustc"
                ],
                "properties": {
                  "rustc": {
                    "type": "object",
                    "required": [
                      "available"
                    ],
                    "properties": {
                      "available": {
                        "const": false
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "cases": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/rust_unavailable_case_guard"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "single_language_payload": {
      "type": "object",
      "required": [
        "schema_version",
        "mode",
        "language",
        "source_mapping_sha256",
        "render_mapping_sha256",
        "summary_status",
        "generator",
        "repository",
        "toolchain",
        "render_paths",
        "official_source_notes",
        "cases"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "source_mapping_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "render_mapping_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "summary_status": {
          "enum": [
            "passed",
            "unavailable",
            "completed_with_findings",
            "completed",
            "skipped",
            "invalid"
          ]
        },
        "generator": {
          "type": "object",
          "required": [
            "tool",
            "research_path",
            "source_commit",
            "source_commit_policy",
            "determinism"
          ],
          "properties": {
            "tool": {
              "type": "string"
            },
            "research_path": {
              "type": "string"
            },
            "source_commit": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9a-f]{40}$"
            },
            "source_commit_policy": {
              "type": "string"
            },
            "determinism": {
              "type": "string"
            }
          }
        },
        "repository": {
          "type": "object",
          "required": [
            "root",
            "render_mapping_snapshot",
            "schema_path"
          ]
        },
        "toolchain": {
          "type": "object"
        },
        "render_paths": {
          "type": "array",
          "minItems": 1
        },
        "official_source_notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "source",
              "summary",
              "url"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "minLength": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/native_case"
          }
        }
      }
    },
    "java_payload": {
      "allOf": [
        {
          "$ref": "#/$defs/single_language_payload"
        },
        {
          "type": "object",
          "required": [
            "mode",
            "language",
            "cases"
          ],
          "properties": {
            "mode": {
              "const": "java-smoke"
            },
            "language": {
              "const": "java"
            },
            "cases": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/java_case"
              }
            }
          }
        }
      ]
    },
    "rust_payload": {
      "allOf": [
        {
          "$ref": "#/$defs/single_language_payload"
        },
        {
          "type": "object",
          "required": [
            "mode",
            "language",
            "cases"
          ],
          "properties": {
            "mode": {
              "const": "rust-smoke"
            },
            "language": {
              "const": "rust"
            },
            "cases": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/rust_case"
              }
            }
          }
        },
        {
          "description": "Rust unavailable payload case shape",
          "if": {
            "required": [
              "toolchain"
            ],
            "properties": {
              "toolchain": {
                "type": "object",
                "required": [
                  "rust"
                ],
                "properties": {
                  "rust": {
                    "type": "object",
                    "required": [
                      "rustc"
                    ],
                    "properties": {
                      "rustc": {
                        "type": "object",
                        "required": [
                          "available"
                        ],
                        "properties": {
                          "available": {
                            "const": false
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "cases": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/rust_unavailable_case_guard"
                }
              }
            }
          }
        }
      ]
    },
    "java_case": {
      "allOf": [
        {
          "$ref": "#/$defs/native_case"
        },
        {
          "properties": {
            "language": {
              "const": "java"
            },
            "render_path": {
              "const": "native_java"
            }
          },
          "required": [
            "language",
            "render_path"
          ],
          "type": "object"
        }
      ]
    },
    "rust_case": {
      "allOf": [
        {
          "$ref": "#/$defs/native_case"
        },
        {
          "properties": {
            "language": {
              "const": "rust"
            },
            "render_path": {
              "const": "native_rust"
            }
          },
          "required": [
            "language",
            "render_path"
          ],
          "type": "object"
        }
      ]
    },
    "native_case": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "language"
            ],
            "properties": {
              "language": {
                "const": "java"
              }
            }
          },
          "then": {
            "required": [
              "render_path"
            ],
            "properties": {
              "render_path": {
                "const": "native_java"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "language"
            ],
            "properties": {
              "language": {
                "const": "rust"
              }
            }
          },
          "then": {
            "required": [
              "render_path"
            ],
            "properties": {
              "render_path": {
                "const": "native_rust"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "passed"
              }
            }
          },
          "then": {
            "required": [
              "outcome",
              "reason",
              "commands"
            ],
            "properties": {
              "outcome": {
                "const": "observed"
              },
              "reason": {
                "type": "null"
              },
              "commands": {
                "type": "object",
                "required": [
                  "run"
                ]
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "runtime_failed"
              }
            }
          },
          "then": {
            "required": [
              "outcome",
              "reason",
              "commands"
            ],
            "properties": {
              "outcome": {
                "const": "runtime_trap"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "commands": {
                "type": "object",
                "required": [
                  "run"
                ]
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "compile_failed"
              }
            }
          },
          "then": {
            "required": [
              "outcome",
              "reason",
              "commands"
            ],
            "properties": {
              "outcome": {
                "const": "compile_failed"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "commands": {
                "type": "object",
                "minProperties": 1
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "unavailable"
              }
            }
          },
          "then": {
            "required": [
              "outcome",
              "reason",
              "commands"
            ],
            "properties": {
              "outcome": {
                "const": "unavailable"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "commands": {
                "type": "object",
                "maxProperties": 0
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "skipped"
              }
            }
          },
          "then": {
            "required": [
              "outcome"
            ],
            "properties": {
              "outcome": {
                "const": "unavailable"
              }
            }
          }
        }
      ],
      "required": [
        "case_id",
        "semantic_case_id",
        "language",
        "profile",
        "operator",
        "fcstm_expression",
        "render_path",
        "render_expression",
        "native_api_family",
        "native_only",
        "native_only_reason",
        "inputs",
        "source_note_ids",
        "status",
        "outcome",
        "reason",
        "commands"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "semantic_case_id": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "enum": [
            "java",
            "rust"
          ]
        },
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "minLength": 1
        },
        "fcstm_expression": {
          "type": "string",
          "minLength": 1
        },
        "render_path": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "native_java",
            "native_rust"
          ]
        },
        "render_expression": {
          "type": "string",
          "minLength": 1
        },
        "native_api_family": {
          "enum": [
            "plain-int32",
            "plain-i32",
            "checked-exact",
            "narrowing-cast",
            "cast",
            "math-floating",
            "renderer-fallback",
            "wrapping",
            "checked",
            "overflowing",
            "saturating"
          ]
        },
        "native_only": {
          "const": true
        },
        "native_only_reason": {
          "const": "no_java_or_rust_template_in_current_repository"
        },
        "inputs": {
          "type": "object",
          "required": [
            "A",
            "B"
          ],
          "properties": {
            "A": {
              "type": "number"
            },
            "B": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "source_note_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "status": {
          "enum": [
            "passed",
            "compile_failed",
            "runtime_failed",
            "skipped",
            "unavailable",
            "unknown"
          ]
        },
        "outcome": {
          "enum": [
            "observed",
            "compile_failed",
            "runtime_trap",
            "unavailable",
            "unknown"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "commands": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/command_result"
          }
        }
      },
      "additionalProperties": true
    },
    "command_result": {
      "type": "object",
      "required": [
        "args",
        "returncode",
        "stdout",
        "stderr",
        "timed_out",
        "duration_seconds",
        "start_error"
      ],
      "properties": {
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "timed_out": {
          "type": "boolean"
        },
        "duration_seconds": {
          "type": [
            "number",
            "string"
          ]
        },
        "start_error": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "rust_unavailable_case_guard": {
      "allOf": [
        {
          "if": {
            "required": [
              "language"
            ],
            "properties": {
              "language": {
                "const": "rust"
              }
            }
          },
          "then": {
            "required": [
              "status",
              "outcome",
              "reason",
              "commands"
            ],
            "properties": {
              "status": {
                "const": "unavailable"
              },
              "outcome": {
                "const": "unavailable"
              },
              "reason": {
                "const": "rustc_unavailable"
              },
              "commands": {
                "type": "object",
                "maxProperties": 0
              }
            }
          }
        }
      ]
    }
  }
}
