    {{ machine_class_name(model) }} *machine,
    const {{ machine_class_name(model) }}ExecutionContext *ctx,
    void *user_data
)
{
    (void)machine;
    (void)ctx;
    (void)user_data;
}

int main(void)
{
    {{ machine_class_name(model) }} machine;
    {{ machine_class_name(model) }}Hooks hooks = {{ machine_class_name(model) | upper }}_HOOKS_INIT;

    {{ machine_class_name(model) }}_init(&machine);
{% if abstract_ns.rows %}
    hooks.{{ abstract_ns.rows[0]['hook_name'] }} = custom_hook;
{% endif %}
    {{ machine_class_name(model) }}_set_hooks(&machine, &hooks, NULL);
    {{ machine_class_name(model) }}_cycle(&machine, NULL, 0u);
    return 0;
}
```

